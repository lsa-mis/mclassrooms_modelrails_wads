<% content_for(:title) { t("workspaces.settings.edit.title") } %>
<%# Unified workspace settings page. Each section is its own form posting to
    the appropriate controller (workspaces#update, settings#update, brandings#update).
    Replaces the previous three standalone edit pages. %>
<div class="max-w-2xl mx-auto px-4 py-16">
  <h1 class="text-3xl font-bold text-text-heading">
    <%= t("workspaces.settings.edit.title") %>
  </h1>

  <div class="mt-8 space-y-12">
    <%= render "workspaces/settings/branding_section", workspace: @workspace %>
    <hr class="border-border">
    <%= render "workspaces/settings/capacity_section", workspace: @workspace %>
  </div>
</div>
