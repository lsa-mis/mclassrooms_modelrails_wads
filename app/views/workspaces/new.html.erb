<% content_for(:title) { t("workspaces.new.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-text-heading">
    <%= t("workspaces.new.title") %>
  </h1>

  <%= form_with model: @workspace, class: "mt-8 space-y-6" do |form| %>
    <%= form.error_summary %>

    <%= form.text_field :name,
          label: t("workspaces.new.name_label"),
          required: true,
          autofocus: true %>

    <%= form.submit t("workspaces.new.submit"), class: "w-full" %>
  <% end %>
</div>
