<% content_for(:title) { t("workspaces.projects.memberships.new.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-3xl font-bold text-text-heading">
    <%= t("workspaces.projects.memberships.new.title") %>
  </h1>

  <%= form_with url: workspace_project_memberships_path(@workspace, @project), method: :post, class: "mt-8 space-y-6" do |form| %>
    <%= form.select :user_id,
          @available_members.map { |m| [m.user.full_name, m.user.id] },
          { label: t("workspaces.projects.memberships.new.user_label"), prompt: t("workspaces.projects.memberships.new.user_prompt") },
          {} %>

    <%= form.select :role,
          [[ t("project_roles.editor"), "editor" ], [ t("project_roles.viewer"), "viewer" ]],
          { label: t("workspaces.projects.memberships.new.role_label") },
          {} %>

    <%= form.submit t("workspaces.projects.memberships.new.submit"), class: "w-full" %>
  <% end %>
</div>
