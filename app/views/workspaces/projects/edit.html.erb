<% content_for(:title) { t("workspaces.projects.edit.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-3xl font-bold text-text-heading">
    <%= t("workspaces.projects.edit.title") %>
  </h1>

  <%= form_with model: @project, url: workspace_project_path(@workspace, @project), method: :patch, class: "mt-8 space-y-6" do |form| %>
    <%= form.error_summary %>

    <%= form.text_field :name,
          label: t("workspaces.projects.edit.name_label"),
          required: true %>

    <%= form.text_area :description,
          label: t("workspaces.projects.edit.description_label"),
          rows: 3 %>

    <%= form.submit t("workspaces.projects.edit.submit"), class: "w-full" %>
  <% end %>

  <% if policy(@project).destroy? %>
    <div class="mt-8 p-4 border border-danger-border rounded-lg flex items-center justify-between gap-4">
      <p class="text-sm text-text-body"><%= t("workspaces.projects.destroy.confirm") %></p>

      <div data-controller="modal" class="shrink-0">
        <button type="button"
                data-action="click->modal#open"
                class="btn-touch-target btn-text btn-text-danger text-sm">
          <%= t("workspaces.projects.destroy.trigger") %>
        </button>

        <%= render "shared/confirm_dialog",
              title: t("workspaces.projects.destroy.title"),
              message: t("workspaces.projects.destroy.confirm"),
              confirm_text: t("workspaces.projects.destroy.confirm_action"),
              confirm_url: workspace_project_path(@workspace, @project),
              confirm_method: :delete,
              variant: :danger %>
      </div>
    </div>
  <% end %>
</div>
