<% content_for(:title) { t("workspaces.edit.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-text-heading">
    <%= t("workspaces.edit.title") %>
  </h1>

  <%= form_with model: @workspace, url: workspace_path(@workspace), method: :patch, class: "mt-8 space-y-6" do |form| %>
    <%= form.error_summary %>

    <%= form.text_field :name,
          label: t("workspaces.edit.name_label"),
          required: true %>

    <%= form.submit t("workspaces.edit.submit"), class: "w-full" %>
  <% end %>
</div>
