<%# Replace the timezone surface (which lives on the notification
    preferences edit page) with a freshly-rendered version. Because the
    partial re-renders the <details> element with no `open` attribute,
    the drawer closes as a side effect of the replace. The summary's
    visible timezone is also refreshed since the partial reads from
    `@preferences.timezone`. %>
<%= turbo_stream.replace "timezone-surface" do %>
  <%= render "account/notification_preferences/timezone_surface", preferences: @preferences %>
<% end %>

<%# Announce the save via the page-level aria-live region. Same target
    that the notification-preferences toggle auto-submit uses (see
    update.turbo_stream.erb), so screen-reader users get a consistent
    "Saved" signal across every preference surface. %>
<%= turbo_stream.update "notifications-live" do %><%= t("notifications.preferences.timezone.saved_announcement") %><% end %>
