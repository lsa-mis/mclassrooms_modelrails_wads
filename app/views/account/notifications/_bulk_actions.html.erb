<div class="flex flex-wrap gap-3 mb-4">
  <div data-controller="modal" class="inline-block">
    <button type="button"
            data-action="click->modal#open"
            class="min-h-[44px] inline-flex items-center px-4 py-2 text-sm font-medium rounded-md bg-surface-raised text-text-body border border-border transition-colors hover:bg-surface-sunken focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-interactive-focus">
      <%= t("notifications.index.mark_all_read.action") %>
    </button>

    <%= render "shared/confirm_dialog",
          title: t("notifications.index.mark_all_read.title"),
          message: t("notifications.index.mark_all_read.confirm"),
          confirm_text: t("notifications.index.mark_all_read.action"),
          confirm_url: mark_all_read_account_notifications_path,
          confirm_method: :post,
          variant: :info %>
  </div>

  <div data-controller="modal" class="inline-block">
    <button type="button"
            data-action="click->modal#open"
            class="min-h-[44px] inline-flex items-center px-4 py-2 text-sm font-medium rounded-md bg-surface-raised text-danger border border-border transition-colors hover:bg-danger-surface focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-interactive-focus">
      <%= t("notifications.index.destroy_all_read.action") %>
    </button>

    <%= render "shared/confirm_dialog",
          title: t("notifications.index.destroy_all_read.title"),
          message: t("notifications.index.destroy_all_read.confirm"),
          confirm_text: t("notifications.index.destroy_all_read.action"),
          confirm_url: destroy_all_read_account_notifications_path,
          confirm_method: :delete,
          variant: :danger %>
  </div>
</div>
