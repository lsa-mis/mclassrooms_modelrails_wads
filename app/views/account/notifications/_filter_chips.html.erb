<%# locals: (current_filter:) -%>
<%
  chips = [
    { key: "all",                path: account_notifications_path },
    { key: "unread",             path: account_notifications_path(filter: "unread") },
    { key: "security",           path: account_notifications_path(category: "security") },
    { key: "account_access",     path: account_notifications_path(category: "account_access") },
    { key: "workspace_activity", path: account_notifications_path(category: "workspace_activity") },
    { key: "project_activity",   path: account_notifications_path(category: "project_activity") },
    { key: "billing",            path: account_notifications_path(category: "billing") }
  ]
  base_classes = "inline-flex items-center min-h-[44px] px-4 py-2 rounded-full text-sm font-medium border transition-colors focus-ring"
  inactive_classes = "bg-surface-raised text-text-body border-border hover:bg-surface-sunken"
  active_classes = "bg-interactive text-text-on-interactive border-interactive"
%>
<nav aria-label="<%= t("notifications.index.filters_aria") %>"
     class="flex flex-wrap gap-2 mb-6">
  <% chips.each do |chip| %>
    <% active = current_filter == chip[:key] %>
    <%= link_to t("notifications.index.filters.#{chip[:key]}"),
          chip[:path],
          class: "#{base_classes} #{active ? active_classes : inactive_classes}",
          aria: { current: active ? "page" : nil } %>
  <% end %>
</nav>
