<section aria-labelledby="notifications-heading"
         class="max-w-3xl mx-auto px-4 py-8
                sm:px-6
                lg:px-8">
  <h1 id="notifications-heading"
      class="text-2xl font-semibold text-text-heading mb-6">
    <%= t("notifications.index.heading") %>
  </h1>

  <%= render "filter_chips", current_filter: @current_filter %>

  <%= render "bulk_actions" %>

  <% if @notifications.empty? %>
    <p class="text-text-body">
      <%= t("notifications.index.empty_all") %>
    </p>
  <% else %>
    <ul class="bg-surface-raised border border-border rounded-lg divide-y divide-border overflow-hidden"
        aria-label="<%= t("notifications.index.heading") %>">
      <%= render partial: "item", collection: @notifications, as: :notification %>
    </ul>
  <% end %>
</section>
