<%# MiClassrooms Phase 5 Task 8 (Brief §14.1): edit announcement — body only;
    the slot is fixed at creation (see _form's read-only slot display). %>
<% content_for(:title) { t(".title") } %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-text-heading"><%= t(".title") %></h1>

  <%= form_with model: @announcement, url: admin_announcement_path(@announcement), method: :patch,
        class: "mt-8 space-y-6" do |form| %>
    <%= render "form", form: form %>
  <% end %>
</div>
