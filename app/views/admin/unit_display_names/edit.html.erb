<%# MiClassrooms Phase 5 Task 11 (Brief §11.4/§14.1): edit unit display name. %>
<% content_for(:title) { t(".title") } %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-text-heading"><%= t(".title") %></h1>

  <%= form_with model: @unit_display_name, url: admin_unit_display_name_path(@unit_display_name), method: :patch,
        class: "mt-8 space-y-6" do |form| %>
    <%= render "form", form: form %>
  <% end %>
</div>
