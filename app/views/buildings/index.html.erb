<%# MiClassrooms Phase 4 Task 8 (Brief §5.3, §14.1): the admin Buildings
    index — FTS5 search (name/nickname/abbreviation via Building.search_name),
    a hidden-buildings toggle, and UI::DataTableComponent for the results.
    Admin-only page (BuildingPolicy#index?), so no view-toggle gating is
    needed here the way rooms/index.html.erb gates its inactive-view links —
    every visitor of this page already cleared that bar in the controller.

    The search form uses the template's shared `auto-submit` Stimulus
    controller (app/javascript/controllers/auto_submit_controller.js): the
    text field submits natively on Enter (no JS needed for that), and the
    hidden-buildings switch fires `change->auto-submit#submit` for an
    immediate toggle — same wiring as shared/_toggle.html.erb and the
    notification-preferences forms, just with a real UI::SwitchComponent
    instead of the plain checkbox partial. %>
<% content_for(:title) { t(".title") } %>

<div class="max-w-5xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-text-heading"><%= t(".title") %></h1>

  <%= form_with url: buildings_path, method: :get, data: { controller: "auto-submit" },
        role: "search", "aria-label": t(".search_label"), class: "mt-6 flex flex-wrap items-end gap-4" do |form| %>
    <%= ui :form_field, label: t(".search_label"), id: "buildings_q", class: "min-w-64 flex-1" do |f| %>
      <%= ui :search_input, name: "q", value: params[:q], label: t(".search_label"), **f.input_attrs %>
    <% end %>

    <%= ui :switch, name: "show_hidden", value: "1", checked: params[:show_hidden] == "1",
          label: t(".show_hidden"), data: { action: "change->auto-submit#submit" } %>

    <button type="submit" class="btn-secondary"><%= t(".search_submit") %></button>
  <% end %>

  <% if @buildings.any? %>
    <%
      columns = [
        { key: :name, label: t(".column_name") },
        { key: :abbreviation, label: t(".column_abbreviation") },
        { key: :campus, label: t(".column_campus") },
        { key: :classroom_count, label: t(".column_classroom_count") },
        { key: :hidden, label: t(".column_hidden") }
      ]
      rows = @buildings.map do |building|
        {
          name: link_to(building.display_name, building_path(building),
                  class: "text-interactive underline-offset-4 hover:underline focus-ring rounded-sm"),
          abbreviation: building.abbreviation,
          campus: building.campus&.description,
          classroom_count: building.rooms.classroom.count,
          hidden: building.hidden? ? ui(:badge, t(".hidden_badge"), variant: :soft, tone: :warning) : nil
        }
      end
    %>
    <%= ui :data_table, columns: columns, rows: rows, per_page: 0, caption: t(".title"), class: "mt-8" %>

    <%= render "shared/pagination", pagy: @pagy %>
  <% else %>
    <p class="mt-6 text-text-muted"><%= t(".no_results") %></p>
  <% end %>
</div>
