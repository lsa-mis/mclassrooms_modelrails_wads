<%= turbo_frame_tag "sign_in_form" do %>
  <div class="mt-8 text-center" role="status" aria-live="polite">
    <div class="mx-auto w-16 h-16 rounded-full bg-info-surface flex items-center justify-center mb-6">
      <%= icon(:envelope, class: "w-8 h-8 text-info") %>
    </div>

    <h2 class="text-xl font-semibold text-text-heading">
      <%= link_to_if Rails.env.development?,
            t("sessions.check_email.title"),
            "/letter_opener",
            target: "_blank", rel: "noopener",
            data: { turbo_frame: "_top" },
            class: "underline decoration-dotted decoration-2 underline-offset-4
                    hover:decoration-solid focus:outline-none focus:ring-2
                    focus:ring-interactive-focus rounded" %>
    </h2>

    <p class="mt-3 text-text-muted">
      <%= t("sessions.check_email.description", email: @email_address) %>
    </p>

    <p class="mt-6 text-sm text-text-muted">
      <%= t("sessions.check_email.expiry") %>
    </p>

    <div class="mt-6">
      <%= link_to t("sessions.check_email.try_again"), main_app.new_session_path,
            class: "text-sm text-interactive underline hover:no-underline
                    focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded",
            data: { turbo_frame: "_top" } %>
    </div>
  </div>
<% end %>
