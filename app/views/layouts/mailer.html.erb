<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style>
      /* Email styles need to be inline */
      .preheader {
        display: none !important;
        visibility: hidden;
        opacity: 0;
        color: transparent;
        height: 0;
        width: 0;
      }
    </style>
  </head>

  <body>
    <span class="preheader"><%= content_for?(:preheader) ? yield(:preheader) : "" %></span>
    <%= yield %>
  </body>
</html>
