<% content_for(:title) { t("pages.privacy.title") } %>

<section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <h1 class="text-4xl font-bold text-text-heading">
    <%= t("pages.privacy.title") %>
  </h1>
  <p class="mt-4 text-text-muted">
    <%= t("pages.privacy.intro") %>
  </p>

  <%# Authoritative U-M policies — MClassrooms defers to these; the rest of the
      page is a plain-language summary specific to this app. Same-tab links (no
      target=_blank) to avoid an unexpected-new-window AAA concern. %>
  <div class="mt-10 rounded-lg border border-border bg-surface-raised p-6">
    <h2 class="text-2xl font-semibold text-text-heading">
      <%= t("pages.privacy.authoritative.title") %>
    </h2>
    <p class="mt-4 text-text-body"><%= t("pages.privacy.authoritative.description") %></p>
    <%# Standalone policy links, so each needs a 44px-min touch target (2.5.5
        AAA) — min-h-11 + inline-flex, the same pattern the footer links use. %>
    <ul class="mt-4 space-y-1">
      <li>
        <%= link_to t("pages.privacy.authoritative.privacy_notice"), "https://umich.edu/about/privacy/",
              class: "inline-flex items-center min-h-11 text-interactive underline hover:no-underline focus-ring rounded" %>
      </li>
      <li>
        <%= link_to t("pages.privacy.authoritative.spg"), "https://spg.umich.edu/policy/601.41",
              class: "inline-flex items-center min-h-11 text-interactive underline hover:no-underline focus-ring rounded" %>
      </li>
    </ul>
  </div>

  <%# What we collect / how we use it — item lists. %>
  <% %w[collection usage].each do |section| %>
    <div class="mt-10">
      <h2 class="text-2xl font-semibold text-text-heading">
        <%= t("pages.privacy.#{section}.title") %>
      </h2>
      <ul class="mt-4 space-y-2">
        <% t("pages.privacy.#{section}.items").each do |item| %>
          <li class="flex items-start gap-2 text-text-body">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-interactive flex-shrink-0" aria-hidden="true"></span>
            <%= item %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <p class="mt-4 text-text-muted"><%= t("pages.privacy.usage.note") %></p>

  <%# Cookies / sharing / your rights — single descriptions. %>
  <% %w[cookies sharing rights].each do |section| %>
    <div class="mt-10">
      <h2 class="text-2xl font-semibold text-text-heading">
        <%= t("pages.privacy.#{section}.title") %>
      </h2>
      <p class="mt-4 text-text-body"><%= t("pages.privacy.#{section}.description") %></p>
    </div>
  <% end %>

  <div class="mt-10 text-sm text-text-muted">
    <p>
      <%= t("pages.privacy.contact_text") %>
      <%= link_to t("pages.privacy.contact_link"), contact_path,
            class: "text-interactive underline hover:no-underline
                    focus-ring rounded" %>.
    </p>
    <p class="mt-2"><%= t("pages.privacy.updated") %>: <%= Date.current.strftime("%B %d, %Y") %></p>
  </div>
</section>
