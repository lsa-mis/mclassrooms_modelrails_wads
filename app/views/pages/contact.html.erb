<% content_for(:title) { t("pages.contact.title") } %>

<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
  <h1 class="text-sm font-medium text-text-muted"><%= t("pages.contact.title") %></h1>
</section>

<%= render "shared/hero",
      title: t("pages.contact.hero.title"),
      subtitle: t("pages.contact.hero.subtitle") %>

<%= render "shared/section",
      title: t("pages.contact.feedback.title"),
      bg: "bg-surface-raised" do %>
  <div class="text-center max-w-2xl mx-auto space-y-4">
    <p class="text-text-body"><%= t("pages.contact.feedback.description") %></p>
    <%# Opens the site-wide feedback modal (adopted lsa_tdx_feedback) rather than
        navigating — feedback is a modal now, reachable from any page. %>
    <%= button_tag t("pages.contact.feedback.cta"),
          type: "button",
          class: "btn-solid btn-primary",
          data: { controller: "feedback", action: "feedback#open" } %>
  </div>
<% end %>

<%= render "shared/section",
      title: t("pages.contact.methods.title"),
      bg: "bg-surface" do %>
  <div class="grid sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
    <%# LSA Technology Services — the app's owner and support path. Custom card
        (shared/feature_card is text-only) so the phone and website are real,
        focusable links. %>
    <div class="p-6 bg-surface-raised rounded-lg border border-border">
      <h3 class="text-lg font-semibold text-text-heading">
        <%= t("pages.contact.methods.lsa_ts.title") %>
      </h3>
      <p class="mt-2 text-text-muted"><%= t("pages.contact.methods.lsa_ts.description") %></p>
      <p class="mt-4 text-text-body">
        <%= t("pages.contact.methods.lsa_ts.phone_label") %>:
        <%= link_to t("pages.contact.methods.lsa_ts.phone"), "tel:+17346150100",
              class: "text-interactive underline hover:no-underline focus-ring rounded" %>
      </p>
      <p class="mt-2">
        <%= link_to t("pages.contact.methods.lsa_ts.website_label"),
              "https://lsa.umich.edu/technology-services/",
              class: "text-interactive underline hover:no-underline focus-ring rounded" %>
      </p>
    </div>

    <%= render "shared/feature_card",
          title: t("pages.contact.methods.rooms.title"),
          description: t("pages.contact.methods.rooms.description") %>
  </div>
<% end %>
