<% content_for(:title) { t("pages.home.hero.title") } %>

<%# The anonymous CTAs are sign-IN, which is unconditional in this codebase —
    only sign-UP is gated by signups_open? (see shared/_header). Never gate
    them on the signup posture: under the default invite_only mode they would
    silently vanish for anonymous visitors. Signed-in users see the landing
    too (root never redirects — the logo means home for every role), so their
    CTAs point into the product instead of at a sign-in form they don't need. %>
<%= render "shared/hero",
      title: t("pages.home.hero.title"),
      subtitle: t("pages.home.hero.subtitle"),
      cta_primary: authenticated? ? t("pages.home.hero.cta_primary_signed_in") : t("pages.home.hero.cta_primary"),
      cta_primary_path: authenticated? ? find_a_room_path : new_session_path,
      cta_secondary: t("pages.home.hero.cta_secondary"),
      cta_secondary_path: about_path %>

<%# Phase 5 Task 8 (Brief §14.1): the home_page announcement slot, shared
    with pages#about and rooms#index via announcements/_banner. %>
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
  <%= render "announcements/banner", announcement: @announcement %>
</div>

<%= render "shared/section",
      title: t("pages.home.features.title"),
      subtitle: t("pages.home.features.subtitle"),
      bg: "bg-surface" do %>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% %w[capacity equipment media floor_plans contacts alerts].each do |feature| %>
      <%= render "shared/feature_card",
            title: t("pages.home.features.#{feature}.title"),
            description: t("pages.home.features.#{feature}.description") %>
    <% end %>
  </div>
<% end %>

<%= render "shared/section", bg: "bg-surface-raised" do %>
  <div class="text-center">
    <h2 class="text-3xl font-bold text-text-heading">
      <%= t("pages.home.cta.title") %>
    </h2>
    <p class="mt-4 text-lg text-text-muted">
      <%= authenticated? ? t("pages.home.cta.subtitle_signed_in") : t("pages.home.cta.subtitle") %>
    </p>
    <div class="mt-8">
      <%= link_to authenticated? ? t("pages.home.cta.button_signed_in") : t("pages.home.cta.button"),
            authenticated? ? find_a_room_path : new_session_path,
            class: "btn-primary px-6 py-3 text-lg" %>
    </div>
  </div>
<% end %>
