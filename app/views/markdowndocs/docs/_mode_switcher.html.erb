<%# Host override of markdowndocs gem's docs/_mode_switcher — for the
    design-token shape only. The gem ships hardcoded Tailwind primitives
    (bg-white, dark:bg-slate-800, border-slate-200, text-slate-700, etc.)
    that don't match this app's semantic-token palette (bg-surface-raised,
    border-border, text-text-body). Until the gem ships token-friendly
    templates (gem issue #16), this override exists to swap the primitives.

    Selected-state cyan signals are kept as-is (they're an intentional UI
    affordance, not a theme token).

    Historically this override ALSO existed to drop a duplicate `id=` on
    the root element — that part is now fixed upstream in
    markdowndocs >= 0.6.1 (gem PR #21 / issue #20). The id-omission below
    is kept aligned with the gem so the host-vs-gem diff stays minimal:
    only the color tokens differ. %>
<%# locals: (current_mode:, available_modes:) %>
<div
  class="
    bg-surface-raised
    rounded-lg
    border
    border-border
    p-4
  "
  data-controller="docs-mode"
  data-docs-mode-current-value="<%= current_mode %>"
>
  <h3 class="
    text-sm
    font-medium
    text-text-body
    mb-3
  ">
    <%= t("markdowndocs.viewing_mode") %>
  </h3>

  <div
    class="space-y-2"
    role="radiogroup"
    aria-label="<%= t('markdowndocs.select_viewing_mode') %>"
  >
    <% available_modes.each do |mode| %>
      <%= form_with(
        url: markdowndocs.preference_path,
        method: :patch,
        data: {
          turbo_action: "replace"
        }
      ) do |f| %>
        <%= f.hidden_field :mode, value: mode %>
        <button
          type="submit"
          role="radio"
          aria-checked="<%= current_mode == mode %>"
          class="
            w-full
            text-left
            p-3
            rounded-lg
            border-2
            transition-all
            duration-150
            <%= (current_mode == mode) ? 'border-cyan-500 bg-cyan-50 dark:bg-cyan-900/40 dark:border-cyan-400' : 'border-border hover:border-border-strong hover:bg-surface-sunken' %>
          "
        >
          <span class="
            block
            font-medium
            <%= (current_mode == mode) ? 'text-cyan-900 dark:text-cyan-100' : 'text-text-heading' %>
          ">
            <%= t("markdowndocs.modes.#{mode}", default: mode.titleize) %>
          </span>
          <% description = t("markdowndocs.modes.#{mode}_description", default: "") %>
          <% if description.present? %>
            <p class="
              text-xs
              mt-1
              <%= (current_mode == mode) ? 'text-cyan-900 dark:text-cyan-100' : 'text-text-body' %>
            ">
              <%= description %>
            </p>
          <% end %>
        </button>
      <% end %>
    <% end %>
  </div>
</div>
