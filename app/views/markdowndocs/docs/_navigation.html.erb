<%# Host override of markdowndocs gem's docs/_navigation — semantic tokens. %>
<%# locals: (rendered_content:, related_docs:, toc_items:) %>
<aside class="sidebar space-y-6">
  <% if toc_items.length >= 3 %>
    <div class="bg-surface-raised rounded-lg shadow-sm p-6">
      <nav aria-label="Table of Contents">
        <h2 class="text-lg font-semibold text-text-heading mb-4">On this page</h2>
        <ul class="space-y-2">
          <% toc_items.each do |item| %>
            <li class="<%= 'ml-4' if item[:level] == 3 %>">
              <a href="#<%= item[:slug] %>" class="text-sm text-text-body hover:text-accent transition-colors flex min-h-11 items-center">
                <%= item[:text] %>
              </a>
            </li>
          <% end %>
        </ul>
      </nav>
    </div>
  <% end %>

  <% if related_docs.any? %>
    <div class="bg-surface-raised rounded-lg shadow-sm p-6 related-docs">
      <h2 class="text-lg font-semibold text-text-heading mb-4">Related Documentation</h2>
      <ul class="space-y-3">
        <% related_docs.each do |related_doc| %>
          <li>
            <%= link_to related_doc.title, markdowndocs.doc_path(related_doc.slug), class: "text-sm text-accent hover:text-accent-hover font-medium transition-colors inline-flex min-h-11 items-center" %>
            <p class="text-xs text-text-body mt-1"><%= related_doc.description %></p>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</aside>
