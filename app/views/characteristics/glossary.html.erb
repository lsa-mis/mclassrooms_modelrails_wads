<%# MiClassrooms Phase 3 Task 7 (Brief §5.1): the filters glossary — every
    characteristic short-code + long description, grouped and alphabetized
    by CharacteristicFilterGroups.glossary (includes filterable: false
    entries, unlike .filters). Single h1 -> one h2 per group -> a <dl> of
    label+badge/description pairs keeps the heading hierarchy correct for
    assistive tech. %>
<% content_for(:title) { t("characteristics.glossary.title") } %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-text-heading"><%= t("characteristics.glossary.title") %></h1>
  <p class="mt-2 text-text-body"><%= t("characteristics.glossary.intro") %></p>

  <%= link_to t("characteristics.glossary.back_link"), find_a_room_path,
        class: "mt-4 text-sm text-interactive underline hover:no-underline
               min-h-11 inline-flex items-center focus-ring rounded" %>

  <% @groups.each do |group| %>
    <section class="mt-8">
      <h2 class="text-lg font-semibold text-text-heading"><%= group.name %></h2>

      <dl class="mt-3 divide-y divide-border border-t border-border">
        <% group.entries.each do |entry| %>
          <div class="py-3">
            <dt class="flex flex-wrap items-center gap-2 font-medium text-text-heading">
              <%= entry.label %>
              <%= ui :badge, entry.short_code, variant: :outline, tone: :neutral %>
            </dt>
            <dd class="mt-1 text-text-body">
              <%= entry.long_description.presence || t("characteristics.glossary.no_description") %>
            </dd>
          </div>
        <% end %>
      </dl>
    </section>
  <% end %>
</div>
