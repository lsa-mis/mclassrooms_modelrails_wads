<%# locals: (title:, id: nil, size: :md, description: nil) -%>
<%#
  Thin adapter over the gem-maintained UI::DialogComponent. Renders the <dialog>
  only (wrapper: false) because callers own the surrounding data-controller="modal"
  wrapper + trigger button. body_id stays "modal-body" to preserve the Turbo Stream
  contract (turbo_stream.append "modal-body"). Existing call sites are unchanged.
-%>
<%= render UI::DialogComponent.new(
      title: title,
      id: id,
      size: size,
      description: description,
      wrapper: false,
      body_id: "modal-body"
    ) do %><%= yield %><% end %>
