<% flash.each do |type, message| %>
  <div role="alert"
       class="p-4 mb-4 rounded-lg
              <%= type == 'alert' ? 'bg-red-50 text-red-800 dark:bg-red-900 dark:text-red-200' : 'bg-green-50 text-green-800 dark:bg-green-900 dark:text-green-200' %>">
    <p><%= message %></p>
  </div>
<% end %>
