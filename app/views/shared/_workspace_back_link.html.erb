<%# Renders a "← Back to <workspace name>" link on every workspace-scoped
    page except the workspace show itself (where it'd be a tautology).
    Rendered inside the layout's <main>, so individual views never need to
    opt in. Lives at the wider max-w-4xl rail so it left-aligns with the
    largest content containers (members, projects, settings). %>
<% if Current.workspace && request.path != workspace_path(Current.workspace) %>
  <nav aria-label="<%= t('navigation.workspace_context_label', workspace: Current.workspace.name) %>"
       class="max-w-4xl mx-auto px-4 pt-6">
    <%= link_to workspace_path(Current.workspace),
          class: "inline-flex items-center gap-1 text-sm text-text-muted
                  hover:text-text-body
                  focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded" do %>
      <%= icon(:arrow_left, size: :sm) %>
      <%= t("navigation.back_to_workspace", workspace: Current.workspace.name) %>
    <% end %>
  </nav>
<% end %>
