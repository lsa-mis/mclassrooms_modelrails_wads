<% if oauth_enabled? %>
  <div class="space-y-3">
    <% enabled_oauth_providers.each do |provider_key, config| %>
      <%= button_to "/auth/#{provider_key}",
            method: :post,
            class: "w-full min-h-[44px] flex items-center justify-center gap-3 px-4 py-3 rounded-md
                    border border-gray-300 dark:border-gray-600
                    bg-white dark:bg-gray-800
                    text-slate-700 dark:text-gray-300
                    hover:bg-gray-50 dark:hover:bg-gray-700
                    focus:outline-none focus:ring-2 focus:ring-sky-700 focus:ring-offset-2
                    cursor-pointer" do %>
        <span class="font-medium"><%= t("oauth.sign_in_with", provider: config[:name]) %></span>
      <% end %>
    <% end %>
  </div>

  <div class="relative my-6">
    <div class="absolute inset-0 flex items-center">
      <div class="w-full border-t border-gray-200 dark:border-gray-700"></div>
    </div>
    <div class="relative flex justify-center text-sm">
      <span class="px-4 bg-white dark:bg-gray-900 text-slate-500 dark:text-gray-400">
        <%= t("oauth.or") %>
      </span>
    </div>
  </div>
<% end %>
