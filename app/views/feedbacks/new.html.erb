<% content_for :title, t("feedback.new.title") %>

<div class="mx-auto max-w-2xl px-4 py-8 space-y-6">
  <div class="space-y-2">
    <h1 class="text-2xl font-bold text-text-heading"><%= t("feedback.new.title") %></h1>
    <p class="text-text-body"><%= t("feedback.new.intro") %></p>
  </div>

  <%= form_with model: @feedback, url: feedback_path, class: "space-y-4" do |form| %>
    <%= form.error_summary %>

    <div class="space-y-2">
      <%= form.label :category, t("feedback.form.category_label"), class: "block text-sm font-medium text-text-body" %>
      <%= form.select :category,
            options_for_select(t("feedback.form.categories").map { |value, label| [ label, value.to_s ] }, @feedback.category),
            { include_blank: t("feedback.form.category_prompt") } %>
    </div>

    <div class="space-y-2">
      <%= form.label :message, t("feedback.form.message_label"), class: "block text-sm font-medium text-text-body" %>
      <%= form.text_area :message, rows: 6, required: true, placeholder: t("feedback.form.message_placeholder") %>
    </div>

    <div class="space-y-2">
      <%= form.label :email, t("feedback.form.email_label"), class: "block text-sm font-medium text-text-body" %>
      <%= form.email_field :email, required: true %>
      <p class="text-sm text-text-muted"><%= t("feedback.form.email_help") %></p>
    </div>

    <%= form.submit t("feedback.form.submit") %>
  <% end %>
</div>
