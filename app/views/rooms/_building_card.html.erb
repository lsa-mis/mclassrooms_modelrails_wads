<%# locals: (building:) %>
<%# MiClassrooms Phase 3 Task 5 (Brief §5.2): building card alongside the
    results list. `reflect_on_attachment` guards the photo branch so a fork
    that drops the `:photo` attachment from Building still renders the
    initials placeholder instead of raising. %>
<%= ui :card, class: "overflow-hidden p-0! gap-0!" do %>
  <% if Building.reflect_on_attachment(:photo) && building.photo.attached? %>
    <%= ui :image,
          src: url_for(building.photo.variant(resize_to_fill: [ 400, 200 ])),
          alt: building.display_name,
          class: "h-28 w-full object-cover" %>
  <% else %>
    <div class="h-28 w-full bg-surface-sunken flex items-center justify-center" aria-hidden="true">
      <span class="text-2xl font-semibold text-text-muted"><%= building_initials(building) %></span>
    </div>
  <% end %>

  <%= ui :card_header, class: "pt-4" do %>
    <%= ui :card_title, building.display_name, level: 3 %>
  <% end %>

  <%= ui :card_content, class: "pb-4" do %>
    <p class="text-sm text-text-muted">
      <%= t("rooms.building_card.classroom_count", count: building.rooms.classroom.listed.count) %>
    </p>
  <% end %>
<% end %>
