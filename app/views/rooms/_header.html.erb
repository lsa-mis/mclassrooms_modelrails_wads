<%# locals: (room:) %>
<%# Redesign v4: breadcrumb + admin banner only — the h1 lives on the media
    stage / empty band. UI::Breadcrumb now accepts href-less items (rendered
    as plain text), so the phase-5 "linked for some viewers, plain for
    others" building crumb no longer needs a hand-rolled trail: a viewer on a
    hidden building simply gets no href. %>
<%= ui :breadcrumb, items: [
      { label: t("rooms.index.title"), href: find_a_room_path },
      { label: room.building.display_name,
        href: (building_path(room.building) if policy(room.building).show?) },
      { label: room.display_name }
    ] %>

<% if RoleResolver.for(Current.user).admin? && room.hidden? %>
  <div class="mt-4">
    <%= ui :banner, t("rooms.show.inactive_banner"), variant: :warning %>
  </div>
<% end %>
