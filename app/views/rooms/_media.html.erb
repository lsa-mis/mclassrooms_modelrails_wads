<%# locals: (room:) %>
<%# MiClassrooms Phase 4 Task 5 (Brief §5.3): the room media suite — main
    photo (lightbox), gallery (up to 5 images per D9, lightbox via
    UI::Gallery's own built-in dialog/modal), a lazy-loaded Pannellum 360°
    panorama, the seating chart (a plain PDF link, or an image lightbox), and
    the floor-plan link. Every slot guards on `attached?`/presence and
    renders nothing when the room has no such asset — most rooms in Task 2's
    seed data carry zero media.

    pannellum.css only needs to load on pages that render a panorama —
    injected via `content_for(:head)` inside the `room.panorama.attached?`
    guard below (shared/_layout_head.html.erb already `yield`s :head) rather
    than app-wide in the stylesheet manifest, so rooms without a panorama
    don't pay for it. %>

<div class="mt-8 space-y-8">
  <% if room.photo.attached? %>
    <%# Single-image lightbox: UI::Dialog (wrapper: true) pairs a trigger
        button with a native <dialog> under one `data-controller="modal"` —
        focus-trap, Escape-to-close, and focus-restore-to-trigger all come
        from the `modal` Stimulus controller for free (modal_controller.js
        records `document.activeElement` on open and refocuses it on close),
        so no extra focus-management JS is needed here. %>
    <%= ui :dialog, title: room.display_name do |dialog| %>
      <% dialog.with_trigger do %>
        <button type="button" data-testid="room-photo-thumb"
                class="block overflow-hidden rounded-md cursor-zoom-in focus-ring">
          <%= ui :image,
                src: rails_representation_path(room.photo.variant(resize_to_fill: [ 150, 150 ], format: :webp)),
                alt: t("rooms.show.photo_alt", room: room.display_name),
                width: 150, height: 150,
                class: "size-[150px] object-cover" %>
        </button>
      <% end %>
      <%= ui :figure do %>
        <%= ui :image,
              src: rails_blob_path(room.photo),
              alt: t("rooms.show.photo_alt", room: room.display_name),
              loading: :eager,
              class: "max-h-[70vh] w-auto rounded-md mx-auto" %>
      <% end %>
    <% end %>
  <% end %>

  <%# Preloads the image attachment + blob for every gallery image in one
      pass — iterating room.gallery_images.ordered and calling
      `gallery_image.image` per row N+1s without it (Bullet raises in test;
      see the analogous building-photo fix in RoomsController#index).
      `includes(image_attachment: :blob)` rather than the auto-generated
      `with_attached_image` scope: with `ActiveStorage.track_variants` on,
      that scope also deep-preloads `variant_records`/`preview_image_attachment`
      on the blob, which this view never touches — Bullet flags THAT as
      unused eager loading (a framework false positive, but one this
      narrower include sidesteps entirely rather than safelisting). %>
  <% gallery_images = room.gallery_images.ordered.includes(image_attachment: :blob).first(5) %>
  <% if gallery_images.any? %>
    <%= ui :gallery do |g| %>
      <% gallery_images.each.with_index(1) do |gallery_image, position| %>
        <%# with_image registers a renders_many slot on g; it has no
            block/output of its own (the component itself is what renders,
            via ui :gallery above), so there is nothing to output here.
            Matches UI::GalleryComponent's own documented usage. %>
        <% alt = t("rooms.show.gallery_alt", room: room.display_name, position: position) %>
        <% g.with_image(src: rails_blob_path(gallery_image.image), alt: alt) %><%# herb:disable erb-no-unused-expressions %>
      <% end %>
    <% end %>
  <% end %>

  <% if room.panorama.attached? %>
    <% content_for(:head) do %>
      <%= stylesheet_link_tag "pannellum", "data-turbo-track": "reload" %>
    <% end %>
    <%# Panorama preview variant doubles as both the static poster image shown
        before the visitor opts in, and the `preview:` value Pannellum itself
        draws inside the booted viewer while the full-resolution panorama
        streams in. %>
    <% panorama_preview_path =
         rails_representation_path(room.panorama.variant(resize_to_limit: [ 1024, 512 ], format: :webp)) %>
    <%= ui :aspect_ratio, ratio: 2,
          class: "relative rounded-md bg-surface-sunken",
          data: {
            controller: "panorama",
            panorama_url_value: rails_blob_path(room.panorama),
            panorama_preview_url_value: panorama_preview_path,
            panorama_label_value: t("rooms.show.panorama_label", room: room.display_name)
          } do %>
      <%= image_tag panorama_preview_path, alt: "", loading: :eager,
            class: "absolute inset-0 size-full object-cover" %>
      <div data-panorama-target="viewer" hidden class="absolute inset-0"></div>
      <div class="absolute inset-0 flex items-center justify-center gap-2">
        <%= ui :button, t("rooms.show.load_panorama"), variant: :outline, tone: :neutral,
              data: { panorama_target: "loadButton", action: "panorama#load" } %>
        <%= render(UI::TooltipComponent.new(text: t("rooms.show.panorama_hint"))) do %>
          <span class="inline-flex items-center justify-center rounded-full bg-surface-overlay p-1.5 shadow-sm">
            <%= icon(:information_circle, size: :sm) %>
          </span>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <% if room.seating_chart.attached? %>
    <% if room.seating_chart.content_type == "application/pdf" %>
      <%= link_to t("rooms.show.seating_chart_link", room: room.display_name),
            rails_blob_path(room.seating_chart, disposition: :inline),
            class: "text-interactive underline-offset-4 hover:underline focus-ring rounded-sm" %>
    <% else %>
      <%= ui :dialog, title: room.display_name do |dialog| %>
        <% dialog.with_trigger do %>
          <button type="button" data-testid="seating-chart-thumb"
                  class="block overflow-hidden rounded-md cursor-zoom-in focus-ring">
            <%= ui :image,
                  src: rails_representation_path(room.seating_chart.variant(resize_to_fill: [ 150, 150 ], format: :webp)),
                  alt: t("rooms.show.seating_chart_alt", room: room.display_name),
                  width: 150, height: 150,
                  class: "size-[150px] object-cover" %>
          </button>
        <% end %>
        <%= ui :figure do %>
          <%= ui :image,
                src: rails_blob_path(room.seating_chart),
                alt: t("rooms.show.seating_chart_alt", room: room.display_name),
                loading: :eager,
                class: "max-h-[70vh] w-auto rounded-md mx-auto" %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <% if room.floor.present? %>
    <%# The route exists (Task 3); the #floor_plan action ships in Task 6. %>
    <%= link_to t("rooms.show.floor_plan_link"), floor_plan_room_path(room), class: "btn-secondary" %>
  <% end %>
</div>
