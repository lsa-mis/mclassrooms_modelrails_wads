<%# locals: (presenter:) %>
<%# Redesign v4 (fidelity pass): ONE card — "What this room supports" — with
    the presenter's data-driven groups as quiet h3 sections. The old flat
    chip cloud is gone (it duplicated every grouped chip right above them),
    and chip labels are now the parsed value without the vendor
    "Category:" prefix (RoomPresenter#chip_label) — the group heading carries
    the category. Grouping stays data-driven via
    CharacteristicDisplayRule#category_override + the team_learning cluster. %>
<%
  feature_groups = [
    [ t("rooms.show.features.seats_layout"), presenter.seats_layout ],
    [ t("rooms.show.features.write_on"), presenter.write_on ],
    [ t("rooms.show.features.show_present"), presenter.show_present ],
    [ t("rooms.show.features.recorded_accessible"), presenter.recorded_accessible ],
    [ t("rooms.show.features.team_based_learning"), presenter.team_based_learning ],
    [ t("rooms.show.features.more"), presenter.other_features ]
  ].reject { |_, chips| chips.blank? }
%>
<% if feature_groups.any? %>
  <div data-testid="characteristic-chips" class="rounded-lg border border-border dark:border-border-strong p-4">
    <h2 class="text-sm font-semibold text-text-heading"><%= t("rooms.show.features_heading") %></h2>
    <div class="mt-3 space-y-4">
      <% single_group = feature_groups.size == 1 %>
      <% feature_groups.each do |heading, chips| %>
        <div>
          <%# A lone group heading directly under the card title is redundant
              noise (audit, Fried) — skip it when there's only one group. %>
          <h3 class="text-sm font-medium text-text-heading <%= 'sr-only' if single_group %>"><%= heading %></h3>
          <ul class="mt-1.5 flex flex-wrap gap-2">
            <% chips.each do |chip| %>
              <li><%= render "rooms/characteristic_chip", chip: chip %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
