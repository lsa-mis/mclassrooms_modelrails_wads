<%# locals: (entry:, label:, pill: false) %>
<%# A filter checkbox whose LABEL raises the glossary description on hover
    and keyboard focus. UI::Tooltip's own contract says not to wrap an
    already-interactive control (its wrapper is a second tab stop) — so this
    follows the component's prescribed alternative: aria-describedby on the
    checkbox input itself, with the bubble/positioning/Esc mechanics borrowed
    verbatim from the component (its constants are the single source of truth
    for the bubble's look and the anchor-positioning fallbacks). Hover
    anywhere on the row or focus the checkbox → bubble shows
    (group-hover/group-focus-within); Esc dismisses without moving focus
    (WCAG 1.4.13) via the same shared floating controller.

    2026-07-16: `pill: true` gives the control the outlined, has-checked-tinted
    PILL treatment. It was the popular-features look; the More-filters panel now
    shares it so every filter reads the same and shows its selected state at a
    glance (Dave). One partial owns the pill so the two callers can't drift. %>
<% checkbox = capture do %>
  <%= ui :checkbox,
        name: "characteristics[]",
        value: entry.short_code,
        label: label,
        checked: Array(params[:characteristics]).include?(entry.short_code),
        id: "characteristics_#{entry.short_code}",
        describedby: (entry.long_description.present? ? "tip_characteristics_#{entry.short_code}" : nil),
        data: { action: "change->filter-form#submitNow" } %>
<% end %>
<%# Inside a pill the row sizes to its content (inline-flex); standalone it is a
    full-width 44px row. Either way min-h-11 keeps the AAA target floor. %>
<% row_display = pill ? "inline-flex" : "flex" %>
<% row = capture do %>
  <% if entry.long_description.present? %>
    <% tip_id = "tip_characteristics_#{entry.short_code}" %>
    <div class="group/tooltip relative <%= row_display %> min-h-11 items-center"
         style="anchor-name: --<%= tip_id %>"
         data-controller="floating"
         data-action="keydown.esc->floating#dismiss mouseleave->floating#clearDismissed focusout->floating#clearDismissed">
      <%= checkbox %>
      <span id="<%= tip_id %>" role="tooltip" style="position-anchor: --<%= tip_id %>"
            class="<%= UI::TooltipComponent.bubble_classes(side: :bottom) %>">
        <%= entry.long_description %>
      </span>
    </div>
  <% else %>
    <div class="<%= row_display %> min-h-11 items-center">
      <%= checkbox %>
    </div>
  <% end %>
<% end %>
<% if pill %>
  <%# The native checkbox stays visible inside the pill — the border/tint is
      presentation, the checkbox is the control. has-checked tints the pill when
      its descendant checkbox is checked. %>
  <span class="inline-flex items-center rounded-full border border-border px-3 sm:px-4 min-h-11
               transition-colors hover:bg-surface-sunken
               has-checked:border-interactive has-checked:bg-interactive-subtle">
    <%= row %>
  </span>
<% else %>
  <%= row %>
<% end %>
