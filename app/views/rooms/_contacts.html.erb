<%# locals: (room:) %>
<%# Contact cards, present-fields-only (pre-release audit, Dave-approved):
    a card of "Not available" rows answers no question. No contact record —
    or one with every field blank — collapses to a single honest sentence;
    a partial record renders only what exists, and a wholly-empty section
    renders no card at all. URLs keep purpose-stating visible text (never a
    bare URL), per the original a11y contract. %>
<% contact = room.room_contact %>
<%
  link_class = "text-interactive underline hover:no-underline focus-ring rounded-sm"
  scheduling_rows = []
  support_rows = []
  if contact
    scheduling_rows << [ t("rooms.show.contacts.scheduling_name"), contact.scheduling_name ] if contact.scheduling_name.present?
    if contact.scheduling_email.present?
      scheduling_rows << [ t("rooms.show.contacts.scheduling_email"),
                           link_to(contact.scheduling_email, "mailto:#{contact.scheduling_email}", class: link_class) ]
    end
    scheduling_rows << [ t("rooms.show.contacts.scheduling_phone"), contact.scheduling_phone ] if contact.scheduling_phone.present?
    if contact.scheduling_detail_url.present?
      scheduling_rows << [ t("rooms.show.contacts.scheduling_detail_label"),
                           link_to(t("rooms.show.contacts.scheduling_detail_link"), contact.scheduling_detail_url, class: link_class) ]
    end
    if contact.scheduling_usage_guidelines_url.present?
      scheduling_rows << [ t("rooms.show.contacts.scheduling_usage_guidelines_label"),
                           link_to(t("rooms.show.contacts.scheduling_usage_guidelines_link"), contact.scheduling_usage_guidelines_url, class: link_class) ]
    end

    support_rows << [ t("rooms.show.contacts.support_department"), contact.support_department_description ] if contact.support_department_description.present?
    if contact.support_email.present?
      support_rows << [ t("rooms.show.contacts.support_email"),
                        link_to(contact.support_email, "mailto:#{contact.support_email}", class: link_class) ]
    end
    support_rows << [ t("rooms.show.contacts.support_phone"), contact.support_phone ] if contact.support_phone.present?
    if contact.support_url.present?
      support_rows << [ t("rooms.show.contacts.support_link_label"),
                        link_to(t("rooms.show.contacts.support_link"), contact.support_url, class: link_class) ]
    end
  end
%>

<div class="space-y-4">
  <% if scheduling_rows.empty? && support_rows.empty? %>
    <%= ui :card do %>
      <%= ui :card_header do %>
        <%= ui :card_title, t("rooms.show.contacts.heading"), level: 2 %>
      <% end %>
      <%= ui :card_content do %>
        <p class="text-sm text-text-body"><%= t("rooms.show.contacts.none") %></p>
      <% end %>
    <% end %>
  <% else %>
    <% { t("rooms.show.contacts.scheduling_heading") => scheduling_rows,
         t("rooms.show.contacts.support_heading") => support_rows }.each do |heading, rows| %>
      <% next if rows.empty? %>
      <%= ui :card do %>
        <%= ui :card_header do %>
          <%= ui :card_title, heading, level: 2 %>
        <% end %>
        <%= ui :card_content do %>
          <dl class="space-y-3 text-sm text-text-body">
            <% rows.each do |label, value| %>
              <div>
                <dt class="font-medium text-text-heading"><%= label %></dt>
                <dd><%= value %></dd>
              </div>
            <% end %>
          </dl>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
