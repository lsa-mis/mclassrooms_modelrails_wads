<%# locals: (search:, filter_groups:) %>
<%# Redesign (2026-07 design sprint): the compact filter card. One merged
    search box (`q` — building OR room, RoomSearch#filter_query), an
    always-visible minimum capacity, promoted "popular features" chips
    (RoomsHelper::PROMOTED_FILTER_CODES — excluded from the More-filters
    panel below so `characteristics[]` is never rendered twice for one code),
    and the characteristic long tail behind a native <details> disclosure —
    the same zero-JS pattern as the result cards. The form stays OUTSIDE the
    results Turbo frame (it never re-renders, so focus/IME state survives
    every filter change); its `id` lets the sort select inside the frame
    submit it via the `form=` attribute, and the filter-form Stimulus
    controller lives on the WRAPPER in index.html.erb (form is a target) so
    those frame-side controls keep working after every re-render. Sort,
    per-page, Reset, and the admin view nav all moved to the results header
    (index.html.erb); the hidden `view` field stays here so a filter submit
    never silently resets an admin's inactive view. %>
<%# role/aria-label MUST ride in html: — form_with silently drops unknown
    top-level kwargs (pre-release audit: the rendered DOM had no search
    landmark at all). %>
<%= form_with url: find_a_room_path, method: :get, id: "find_a_room_form",
      data: { turbo_frame: "find_a_room_results", turbo_action: "advance",
              filter_form_target: "form" },
      html: { role: "search", "aria-label": t("rooms.filters.form_label") },
      class: "mt-6 rounded-lg border border-border dark:border-border-strong p-4 space-y-3 sm:space-y-4" do |form| %>

  <%# The card is a role="search" landmark with its own accessible name, so the
      visible "Filters" title is redundant chrome — kept sr-only for
      screen-reader heading nav. (The standalone glossary link was dropped: the
      per-filter popovers are the inline glossary.) %>
  <h2 class="sr-only"><%= t("rooms.filters.card_title") %></h2>

  <%= hidden_field_tag :view, params[:view] if params[:view].present? %>
  <%# Same contract as :view — the Saved toggle isn't a form control, so
      without this every filter submit would silently drop the shortlist view. %>
  <%= hidden_field_tag :saved, params[:saved] if params[:saved].present? %>

  <%# Search on its own full-width row. Compact visible label ("Search"); the
      input's aria-label keeps the descriptive superset name and the placeholder
      is only a hint — see the search_accessible_label locale note. %>
  <%= ui :form_field, label: t("rooms.filters.search_label"), id: "filter_q" do |f| %>
    <%= ui :search_input, name: "q", value: params[:q],
          label: t("rooms.filters.search_accessible_label"),
          placeholder: t("rooms.filters.search_placeholder"),
          data: { action: "input->filter-form#submit" }, **f.input_attrs %>
  <% end %>

  <%# School/College + Capacity range, promoted OUT of the More-filters panel to
      just under Search (2026-07-16, Dave): School/College is a primary
      room-finding facet, and min/max capacity are two ends of ONE range — keep
      the pair together and always visible instead of split across the fold. %>
  <div class="flex flex-wrap items-end gap-x-6 gap-y-3">
    <div class="grow basis-56 min-w-0">
      <%= ui :form_field, label: t("rooms.filters.unit_label"), id: "filter_unit_id" do |f| %>
        <%= ui :select, name: "unit_id",
              options: [ [ "", t("rooms.filters.unit_all") ] ] + RoomSearch.unit_options.map { |u| [ u.id, u.display_name ] },
              selected: params[:unit_id],
              data: { action: "change->filter-form#submitNow" }, **f.input_attrs %>
      <% end %>
    </div>

    <%# One capacity RANGE (min–max), not two scattered fields. Neither input
        carries a `max=` HTML attribute: an over-bound value would make
        form.requestSubmit() silently fail constraint validation and freeze
        every later live filter change — RoomSearch treats an over-bound bound
        as unbounded and returns an honest "0 rooms found" instead. %>
    <fieldset class="shrink-0">
      <legend class="text-sm font-medium text-text-heading"><%= t("rooms.filters.capacity_label") %></legend>
      <div class="mt-1 flex items-center gap-2">
        <label class="sr-only" for="filter_capacity_min"><%= t("rooms.filters.capacity_min_label") %></label>
        <%= number_field_tag :capacity_min, params[:capacity_min], min: 0,
              id: "filter_capacity_min", placeholder: t("rooms.filters.capacity_min_short"),
              class: "form-field w-20",
              data: { action: "input->filter-form#submit" } %>
        <span aria-hidden="true" class="text-text-muted">–</span>
        <label class="sr-only" for="filter_capacity_max"><%= t("rooms.filters.capacity_max_label") %></label>
        <%= number_field_tag :capacity_max, params[:capacity_max], min: 0,
              id: "filter_capacity_max", placeholder: t("rooms.filters.capacity_max_short"),
              class: "form-field w-20",
              data: { action: "input->filter-form#submit" } %>
      </div>
    </fieldset>
  </div>

  <% promoted = promoted_filter_entries(filter_groups) %>
  <% if promoted.any? %>
    <fieldset>
      <legend class="text-sm font-semibold text-text-heading"><%= t("rooms.filters.popular_legend") %></legend>
      <div class="mt-2 flex flex-wrap gap-2">
        <% promoted.each do |entry| %>
          <%= render "characteristic_checkbox", entry: entry, pill: true,
                label: characteristic_labels.fetch(entry.short_code, entry.label) %>
        <% end %>
      </div>
    </fieldset>
  <% end %>

  <%# Named group (group/disclosure): the checkbox tooltips inside use the
      UNNAMED `group` variants from UI::Tooltip's constants, and Tailwind's
      plain group-hover/focus-within match ANY .group ancestor — an unnamed
      group on this details would raise every bubble whenever focus sits
      anywhere in the panel (e.g. on this summary after a click). %>
  <%= tag.details id: "more_filters", open: more_filters_open?(params),
        class: "group/disclosure mt-3" do %>
    <%# A filled, pressable row (2026-07-14 discoverability pass): a bare bold
        label + chevron read as a section HEADING and blended into the card, so
        the summary now sits on a recessed bg-surface-sunken plate with the
        chevron pushed to the right edge — the resting fill signals "control"
        before any hover. The verb is state-aware with NO JS via the named
        group/disclosure: "More filters" collapsed, "Hide filters" once open. %>
    <summary class="list-none min-h-11 flex items-center gap-2 cursor-pointer
                    rounded-md px-3 bg-surface-sunken dark:bg-surface-raised
                    text-sm font-semibold text-text-heading focus-ring
                    transition-colors hover:text-interactive">
      <span class="group-open/disclosure:hidden"><%= t("rooms.filters.more_filters") %></span>
      <span class="hidden group-open/disclosure:inline"><%= t("rooms.filters.hide_filters") %></span>
      <%# Always-rendered holder (hidden at zero) so syncPanelCount has a stable
          node to fill after frame renders — the count text comes from the
          frame's [data-panel-count] mirror (backlog #7). Badge + chevron are
          grouped and pushed to the right edge TOGETHER, so the count sits tight
          against the chevron (not floating mid-bar) whether or not it shows. %>
      <% applied = panel_filter_count(params) %>
      <span class="ml-auto flex items-center gap-2">
        <%= tag.span hidden: applied.zero?, data: { panel_badge: true } do %>
          <%= ui :badge, t("rooms.filters.applied_count", count: applied), variant: :soft, tone: :info %>
        <% end %>
        <%= icon(:chevron_down, size: :sm,
              class: "text-text-muted transition-transform group-open/disclosure:rotate-180") %>
      </span>
    </summary>

    <div class="pt-3 space-y-5">
      <%# Characteristic filters as pills, grouped by category — each group spans
          the full panel width so long labels flow. School/College and the
          capacity range moved up to the always-visible filters above the
          Popular-features row. %>
      <div class="space-y-5">
        <% panel_filter_groups(filter_groups).each do |group, entries| %>
          <fieldset>
            <legend class="pb-2 text-sm font-semibold text-text-heading"><%= characteristic_group_name(group) %></legend>
            <div class="flex flex-wrap gap-2">
              <% entries.each do |entry| %>
                <%= render "characteristic_checkbox", entry: entry, pill: true,
                      label: characteristic_labels.fetch(entry.short_code, entry.label) %>
              <% end %>
            </div>
          </fieldset>
        <% end %>
      </div>

      <%# No-JS fallback only: filter-form#connect hides this the moment JS is
          on (filtering is live). Kept in the DOM so the form still submits
          without JavaScript. The glossary link moved to the card header. %>
      <div class="flex flex-wrap items-center gap-4">
        <button type="submit" class="btn-secondary"
                data-filter-form-target="applyButton"><%= t("rooms.filters.submit") %></button>
      </div>
    </div>
  <% end %>
<% end %>
