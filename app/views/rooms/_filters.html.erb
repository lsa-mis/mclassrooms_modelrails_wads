<%# locals: (search:, filter_groups:) %>
<%# Redesign (2026-07 design sprint): the compact filter card. One merged
    search box (`q` — building OR room, RoomSearch#filter_query), an
    always-visible minimum capacity, promoted "popular features" chips
    (RoomsHelper::PROMOTED_FILTER_CODES — excluded from the More-filters
    panel below so `characteristics[]` is never rendered twice for one code),
    and the characteristic long tail behind a native <details> disclosure —
    the same zero-JS pattern as the result cards. The form stays OUTSIDE the
    results Turbo frame (it never re-renders, so focus/IME state survives
    every filter change); its `id` lets the sort select inside the frame
    submit it via the `form=` attribute, and the filter-form Stimulus
    controller lives on the WRAPPER in index.html.erb (form is a target) so
    those frame-side controls keep working after every re-render. Sort,
    per-page, Reset, and the admin view nav all moved to the results header
    (index.html.erb); the hidden `view` field stays here so a filter submit
    never silently resets an admin's inactive view. %>
<%= form_with url: find_a_room_path, method: :get, id: "find_a_room_form",
      data: { turbo_frame: "find_a_room_results", turbo_action: "advance",
              filter_form_target: "form" },
      role: "search", "aria-label": t("rooms.filters.form_label"),
      class: "mt-6 rounded-lg border border-border p-4 space-y-4" do |form| %>

  <div class="flex items-baseline justify-between gap-4">
    <h2 class="text-sm font-semibold text-text-heading"><%= t("rooms.filters.card_title") %></h2>
    <%# Deliberately NOT frame-targeted: a header Reset must clear the form's
        own inputs too, which only a fresh page render guarantees (the form
        lives outside the results frame). The chips row's Clear-all handles
        the fast in-frame path with filter-form#clear. %>
    <%= link_to t("rooms.filters.reset"),
          find_a_room_path(params[:view].present? ? { view: params[:view] } : {}),
          class: "text-sm text-interactive underline hover:no-underline
                 min-h-11 inline-flex items-center focus-ring rounded" %>
  </div>

  <%= hidden_field_tag :view, params[:view] if params[:view].present? %>

  <div class="flex flex-wrap items-end gap-x-6 gap-y-4">
    <div class="grow basis-64">
      <%# Compact visible label ("Search"); the input's aria-label keeps the
          descriptive superset name and the placeholder is only a hint —
          see the search_accessible_label locale note. %>
      <%= ui :form_field, label: t("rooms.filters.search_label"), id: "filter_q" do |f| %>
        <%= ui :search_input, name: "q", value: params[:q],
              label: t("rooms.filters.search_accessible_label"),
              placeholder: t("rooms.filters.search_placeholder"),
              data: { action: "input->filter-form#submit" }, **f.input_attrs %>
      <% end %>
    </div>

    <div>
      <label for="filter_capacity_min" class="mb-1 block text-sm font-semibold text-text-heading">
        <%= t("rooms.filters.capacity_label") %>
      </label>
      <span class="flex items-center gap-2">
        <%# No `max:` — a max attribute makes form.requestSubmit() fail
            constraint validation SILENTLY for over-bound values, freezing
            every subsequent live filter change. An over-bound minimum should
            return an honest "0 rooms found" instead.
            The "minimum" suffix is a hint, wired via aria-describedby: the
            accessible name stays "Capacity", AT still hears the qualifier. %>
        <%= number_field_tag :capacity_min, params[:capacity_min],
              min: 0, class: "form-field w-24", id: "filter_capacity_min",
              "aria-describedby": "filter_capacity_min_hint",
              data: { action: "input->filter-form#submit" } %>
        <span id="filter_capacity_min_hint" class="text-sm font-medium text-text-body"><%= t("rooms.filters.capacity_min_hint") %></span>
      </span>
    </div>
  </div>

  <% promoted = promoted_filter_entries(filter_groups) %>
  <% if promoted.any? %>
    <fieldset>
      <legend class="text-sm font-semibold text-text-heading"><%= t("rooms.filters.popular_legend") %></legend>
      <div class="mt-2 flex flex-wrap gap-2">
        <% promoted.each do |entry| %>
          <%# Pill treatment (sprint prototype): the native checkbox stays
              visible inside the pill — the border/tint is presentation, the
              checkbox is the control. %>
          <span class="inline-flex items-center rounded-full border border-border px-4 min-h-11
                       has-checked:border-interactive has-checked:bg-interactive-subtle">
            <%= ui :checkbox,
                  name: "characteristics[]",
                  value: entry.short_code,
                  label: characteristic_labels.fetch(entry.short_code, entry.label),
                  checked: Array(params[:characteristics]).include?(entry.short_code),
                  id: "characteristics_#{entry.short_code}",
                  data: { action: "change->filter-form#submitNow" } %>
          </span>
        <% end %>
      </div>
    </fieldset>
  <% end %>

  <%= tag.details id: "more_filters", open: more_filters_open?(params),
        class: "group border-t border-border" do %>
    <summary class="list-none min-h-11 flex items-center gap-2 cursor-pointer
                    text-sm font-semibold text-text-heading focus-ring rounded">
      <%= t("rooms.filters.more_filters") %>
      <% if (applied = panel_filter_count(params)).positive? %>
        <%= ui :badge, t("rooms.filters.applied_count", count: applied), variant: :soft, tone: :info %>
      <% end %>
      <%= icon(:chevron_down, size: :sm,
            class: "text-text-muted transition-transform group-open:rotate-180") %>
    </summary>

    <div class="pt-2 space-y-4">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <%= ui :form_field, label: t("rooms.filters.unit_label"), id: "filter_unit_id" do |f| %>
          <%= ui :select, name: "unit_id",
                options: [ [ "", t("rooms.filters.unit_all") ] ] + RoomSearch.unit_options.map { |u| [ u.id, u.display_name ] },
                selected: params[:unit_id],
                data: { action: "change->filter-form#submitNow" }, **f.input_attrs %>
        <% end %>

        <%= ui :form_field, label: t("rooms.filters.capacity_max_label"), id: "filter_capacity_max" do |f| %>
          <%# No `max:` for the same silent-block reason as capacity_min above;
              RoomSearch already treats an over-bound max as unbounded. %>
          <%= number_field_tag :capacity_max, params[:capacity_max],
                min: 0, class: "form-field", id: f.input_attrs[:id],
                data: { action: "input->filter-form#submit" } %>
        <% end %>
      </div>

      <fieldset class="space-y-4">
        <legend class="text-sm font-semibold text-text-heading"><%= t("rooms.filters.characteristics_legend") %></legend>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <% panel_filter_groups(filter_groups).each do |group, entries| %>
            <fieldset class="rounded-md border border-border p-4">
              <legend class="px-1 text-sm font-medium text-text-heading"><%= characteristic_group_name(group) %></legend>
              <div class="mt-2 space-y-2">
                <% entries.each do |entry| %>
                  <%# No `title:` — a native title on the 16px input is mouse-hover-only
                      and not reliably exposed to AT. The visible checkbox label IS the
                      accessible name; the long description belongs to the glossary,
                      not every filter checkbox. %>
                  <%= ui :checkbox,
                        name: "characteristics[]",
                        value: entry.short_code,
                        label: characteristic_labels.fetch(entry.short_code, entry.label),
                        checked: Array(params[:characteristics]).include?(entry.short_code),
                        id: "characteristics_#{entry.short_code}",
                        data: { action: "change->filter-form#submitNow" } %>
                <% end %>
              </div>
            </fieldset>
          <% end %>
        </div>
      </fieldset>

      <div class="flex flex-wrap items-center gap-4">
        <%# The explicit submit is the no-JS fallback — live submits make it a
            no-op with JS on, so it stays visually secondary. %>
        <button type="submit" class="btn-secondary"><%= t("rooms.filters.submit") %></button>
        <%= link_to t("rooms.filters.glossary_link"), filters_glossary_path,
              class: "text-sm text-interactive underline hover:no-underline
                     min-h-11 inline-flex items-center focus-ring rounded" %>
      </div>
    </div>
  <% end %>
<% end %>
