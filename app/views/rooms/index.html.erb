<%# Redesign (2026-07 design sprint) of the Phase 3 Task 5 page: filter card
    (_filters.html.erb) above, results Turbo frame below. The frame now opens
    with a STICKY results header — live count, removable applied-filter chips,
    sort, and the admin view nav — so the live feedback stays in view while
    the card grid scrolls (the sprint's core finding: the old full-height
    filter form pushed results below the fold, making the already-working
    Turbo updates invisible). Filter submissions still target only the
    `find_a_room_results` frame; the heading/announcement/form chrome outside
    it never re-renders. The `[busy]` opacity utility on the frame is the
    pending state — Turbo sets/clears the attribute itself.

    The filter-form Stimulus controller sits on this wrapper (not the <form>)
    so frame-side controls — the sort select, wired to the form via its
    `form=` attribute — keep their actions after every frame re-render.

    Phase 5 Task 8: the announcement banner is the SHARED announcements/_banner
    partial (also rendered on pages#home/#about) — see that partial for the
    no-op-on-nil and landmark-<aside> contract. %>
<% content_for(:title) { t("rooms.index.title") } %>

<div class="max-w-5xl mx-auto px-4 py-8" data-controller="filter-form"
     data-action="turbo:frame-render->filter-form#frameRendered">
  <h1 class="text-2xl font-bold text-text-heading"><%= t("rooms.index.title") %></h1>
  <p class="mt-1 text-sm text-text-body"><%= t("rooms.index.subtitle") %></p>

  <%= render "announcements/banner", announcement: @announcement %>

  <%= render "filters", search: @search, filter_groups: @filter_groups %>

  <%# Persistent announcer OUTSIDE the frame (audit, Léonie): a live region
      that is itself replaced on every frame swap is not reliably announced —
      filter-form#frameRendered copies the fresh count here after each render. %>
  <p id="results_announcer" aria-live="polite" class="sr-only"></p>

  <%= turbo_frame_tag "find_a_room_results", role: "region",
        "aria-label": t("rooms.index.results_frame_label"),
        class: "block mt-6 motion-safe:transition-opacity aria-busy:opacity-60" do %>
    <% current_view = params[:view].presence_in(RoomsController::VIEWS) || "active" %>
    <div class="sticky top-0 z-10 bg-surface-raised shadow-sm border-b border-border px-2 py-3
                flex flex-wrap items-center gap-x-4 gap-y-2">
      <%# Visible count only — announcements come from the persistent
          #results_announcer above; the filter sentence stays as a plain
          sr-only sibling for reading order. %>
      <p data-results-count
         class="text-xl font-semibold text-text-heading m-0 motion-safe:animate-count-flash rounded px-1 -mx-1">
        <%= t("rooms.index.results_summary", count: @pagy.count) %>
      </p>
      <% if @search.summary.present? %>
        <span class="sr-only"><%= @search.summary %></span>
      <% end %>
      <%# Hidden mirror of the panel-applied count (backlog #7): the badge on
          the More-filters summary lives OUTSIDE this frame, so a frame-only
          re-render left it stale. filter_form_controller#syncPanelCount
          copies this text into [data-panel-badge] after every render —
          same out-of-frame relay pattern as #results_announcer. %>
      <% panel_applied = panel_filter_count(params) %>
      <span data-panel-count hidden><%= t("rooms.filters.applied_count", count: panel_applied) if panel_applied.positive? %></span>

      <%# Chips and Clear-all are FULL visits, not frame navigations (panel
          review, Jorge/Léonie): a frame swap can't update the out-of-frame
          form's inputs (stale checkboxes/query re-submit on the next change)
          and destroys the focused element, dropping AT users to <body>. A
          fresh render clears both problems; Turbo Drive keeps it fast. %>
      <% chips = filter_chips(@filter_params) %>
      <% if chips.any? %>
        <span class="flex flex-wrap items-center gap-2">
          <% chips.each do |label, url| %>
            <%= link_to url,
                  data: { turbo_frame: "_top" },
                  class: "inline-flex items-center gap-1.5 rounded-full border border-border
                         bg-surface-sunken px-4 min-h-11 text-sm text-text-body focus-ring
                         transition-colors hover:border-border-strong hover:text-text-heading" do %>
              <span class="sr-only"><%= t("rooms.index.chips.remove") %></span><%= label %><span aria-hidden="true" class="font-semibold">×</span>
            <% end %>
          <% end %>
        </span>
      <% end %>

      <span class="ms-auto flex flex-wrap items-center gap-4">
        <%# Shortlist view toggle: a FILTER state, so it composes with the
            card's filters (and appears as a removable chip when active).
            _top full visit — same staleness rule as the view nav. %>
        <% saved_active = params[:saved].present? %>
        <%= link_to find_a_room_path(saved_active ? @filter_params.to_h.except("saved") : @filter_params.to_h.merge("saved" => "1")),
              data: { turbo_frame: "_top" },
              "aria-current": (saved_active ? "true" : nil),
              class: "text-sm min-h-11 inline-flex items-center gap-1 focus-ring rounded
                     #{saved_active ? 'font-semibold text-text-heading' : 'text-interactive underline hover:no-underline'}" do %>
          <%= t("rooms.save.saved_filter") %> (<span id="saved_rooms_count"><%= @saved_count %></span>)
        <% end %>
        <%# Lives inside the frame (re-renders with results) but submits the
            form outside it via `form=` — sort is a property of the results,
            so it belongs with them (sprint decision; per-page dropped). %>
        <label class="flex items-center gap-2 text-sm text-text-body whitespace-nowrap" for="filter_sort">
          <%= t("rooms.filters.sort_label") %>
          <%= ui :select, name: "sort", form: "find_a_room_form", id: "filter_sort",
                options: RoomSearch::SORTS.map { |s| [ s, t("rooms.filters.sorts.#{s}") ] },
                selected: @search.sort,
                data: { action: "change->filter-form#submitNow" } %>
        </label>

        <% if policy(Room).view_inactive? %>
          <nav aria-label="<%= t('rooms.index.views_nav_label') %>" class="flex flex-wrap gap-4">
            <%# Full visits (not frame): a frame nav leaves the form's hidden
                `view` field stale, so the NEXT filter change would silently
                revert the admin's view — a fresh render re-renders the field. %>
            <% RoomsController::VIEWS.each do |view_key| %>
              <%= link_to t("rooms.index.views.#{view_key}"), find_a_room_path(view: view_key),
                    data: { turbo_frame: "_top" },
                    "aria-current": (current_view == view_key ? "page" : nil),
                    class: "text-sm min-h-11 inline-flex items-center focus-ring rounded
                           #{current_view == view_key ? 'font-semibold text-text-heading' : 'text-interactive underline hover:no-underline'}" %>
            <% end %>
          </nav>
        <% end %>
      </span>
    </div>

    <% if current_view != "active" %>
      <%# Sprint rule: entering admin mode is quiet, BEING in it is
          unmistakable. role: :note (panel review, Léonie): this is persistent
          context, not a status update — as a live region it re-announced its
          unchanged text on every filter keystroke. Only reachable when
          base_scope's view_inactive? authorize passed. %>
      <div class="mt-4">
        <%= ui :alert, tone: :warning, role: :note do |a| %>
          <% a.with_alert_description do %>
            <p class="text-sm"><%= t("rooms.index.inactive_view_notice.#{current_view}") %></p>
            <%= link_to t("rooms.index.inactive_view_notice.back_to_active"),
                  find_a_room_path,
                  data: { turbo_frame: "_top" },
                  class: "text-sm text-interactive underline hover:no-underline
                         min-h-11 inline-flex items-center focus-ring rounded" %>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <% if @rooms.any? %>
      <h2 class="sr-only"><%= t("rooms.index.results_heading") %></h2>
      <ul class="mt-4 grid gap-4 md:grid-cols-2">
        <% @rooms.each do |room| %>
          <%= render "room_row", room: room, note_stats: @note_stats,
                saved_room_ids: @saved_room_ids %>
        <% end %>
      </ul>

      <%= render "shared/pagination", pagy: @pagy %>
    <% else %>
      <%# One clear control per page (audit, Fried): the filter card's own
          "Clear filters" is always visible — no duplicate button here. %>
      <div class="py-12 text-center">
        <p class="text-text-body font-medium"><%= t("rooms.index.no_results") %></p>
        <p class="mt-1 text-sm text-text-body"><%= t("rooms.index.no_results_hint") %></p>
      </div>
    <% end %>
  <% end %>
</div>
