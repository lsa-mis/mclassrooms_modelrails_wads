<%# MiClassrooms Phase 4 Task 5 (Brief §5.3): room detail — header (breadcrumb,
    h1, attribute list, admin-only inactive banner), the media suite (photo
    lightbox, gallery, panorama, seating chart, floor-plan link),
    characteristic chips, grouped features, contacts, read-only notes, and
    the copy-to-clipboard share button. %>
<% content_for(:title) { @room.display_name } %>

<div class="max-w-5xl mx-auto px-4 py-8">
  <%= render "rooms/header", room: @room, presenter: @presenter %>

  <%# Phase 5 Task 6 (Brief §14.1): gated on edit? (admin OR the room's unit
      editor while it's visible), not update? directly — edit?/update? are
      aliased (RoomPolicy), but this is the "can this actor reach the edit
      page at all" question the link itself asks. An editor now lands on a
      curated-fields-only form (RoomPolicy#manage_media? stays admin-only,
      gated inside rooms/edit.html.erb itself). %>
  <% if policy(@room).edit? %>
    <div class="mt-4">
      <%= link_to t("rooms.show.edit_link"), edit_room_path(@room), class: "btn-secondary" %>
    </div>
  <% end %>

  <%= render "rooms/visibility_actions", room: @room %>

  <%= render "rooms/media", room: @room %>

  <%= render "rooms/characteristics", presenter: @presenter %>

  <%= render "rooms/contacts", room: @room %>

  <%= render "notes/list", notable: @room %>

  <div class="mt-8"
       data-controller="share"
       data-share-text-value="<%= @presenter.share_text %>"
       data-share-copied-message-value="<%= t('rooms.show.share.copied') %>">
    <button type="button" data-action="share#copy" class="btn-secondary">
      <%= t("rooms.show.share.button") %>
    </button>
    <span data-share-target="status" aria-live="polite"
          class="mt-2 block text-sm text-text-body"></span>
  </div>
</div>
