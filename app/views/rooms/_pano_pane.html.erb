<%# locals: (room:) %>
<%# The click-to-load Pannellum stage, unchanged in behavior from the
    original media suite: static poster (the preview variant doubles as
    Pannellum's own `preview:`), explicit opt-in load button, lazy
    `import("pannellum")`. `data-turbo-permanent` + id keep the booted WebGL
    viewer alive across morphs (panel review, Wathan). pannellum.css loads
    only here via content_for(:head). %>
<% content_for(:head) do %>
  <%= stylesheet_link_tag "pannellum", "data-turbo-track": "reload" %>
<% end %>
<%# :poster is defined on the attachment (app/models/room.rb) so the ingest
    task pre-processes the SAME variant this pane serves. %>
<% panorama_preview_path = rails_representation_path(room.panorama.variant(:poster)) %>
<%= ui :aspect_ratio, ratio: 2,
      id: "room_panorama_stage",
      class: "relative rounded-md bg-surface-sunken overflow-hidden",
      data: {
        turbo_permanent: "",
        controller: "panorama",
        panorama_url_value: rails_blob_path(room.panorama),
        panorama_preview_url_value: panorama_preview_path,
        panorama_label_value: t("rooms.show.panorama_label", room: room.display_name)
      } do %>
  <%= image_tag panorama_preview_path, alt: "", loading: :eager,
        class: "absolute inset-0 size-full object-cover" %>
  <%# Focus indicator comes from .pnlm-container:focus-visible in
      application.css (INSET — the stage's overflow-hidden clips the app's
      standard outward focus-ring). %>
  <div data-panorama-target="viewer" hidden class="absolute inset-0"></div>
  <%# The whole overlay is a target: it paints OVER the viewer, so the
      controller must hide ALL of it on load or it eats every drag/zoom. %>
  <div data-panorama-target="overlay" class="absolute inset-0 flex items-center justify-center">
    <%# The Load button sits over an ARBITRARY poster photo — contrast against a
        raster is unknowable (and axe skips it), so it gets a fully opaque
        surface-overlay plate for deterministic AAA text/border contrast. The
        button carries its OWN hint (2026-07-14): the button is already the
        focusable trigger, so we follow UI::Tooltip's prescribed
        interactive-control pattern — aria-describedby + the bubble reused via
        `bubble_classes`, NOT the component's own tabbable wrapper (which would
        add a nested second tab stop next to the button). Hover or focus the
        button → bubble; Esc dismisses via the shared floating controller
        (WCAG 1.4.13). This replaces the old standalone info chip. %>
    <% pano_tip_id = "tip_load_panorama_#{room.id}" %>
    <div class="group/tooltip relative inline-flex min-h-11 items-center"
         style="anchor-name: --<%= pano_tip_id %>"
         data-controller="floating"
         data-action="keydown.esc->floating#dismiss mouseleave->floating#clearDismissed focusout->floating#clearDismissed">
      <%= ui :button, t("rooms.show.load_panorama"), variant: :outline, tone: :neutral,
            class: "bg-surface-overlay shadow-sm",
            aria: { describedby: pano_tip_id },
            data: { action: "panorama#load" } %>
      <span id="<%= pano_tip_id %>" role="tooltip" style="position-anchor: --<%= pano_tip_id %>"
            class="<%= UI::TooltipComponent.bubble_classes(side: :top) %>">
        <%= t("rooms.show.panorama_hint") %>
      </span>
    </div>
  </div>
<% end %>
