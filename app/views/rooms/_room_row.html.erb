<%# locals: (room:, note_stats: {}, saved_room_ids: {}) %>
<%# Result card, restructured per Dave's calls on the pre-release audit:
    the TITLE links straight to the room page (no more disclosure-then-link
    two-step — a link can't live inside <summary>, so the header row sits
    outside the disclosure entirely); tags are the room's DISTINCTIVE,
    filterable characteristics; alerts/notes get an always-visible line; and
    the "Details" disclosure holds the full characteristic set as chiclets
    with description tooltips (chiclets won over the duplicate text list). %>
<li class="rounded-lg border border-border dark:border-border-strong p-4 scroll-mt-24">
  <div class="flex flex-wrap items-center gap-4">
    <% if (thumbnail = room_thumbnail_image(room)) %>
      <%= ui :image,
            src: url_for(thumbnail.image.variant(resize_to_fill: [ 96, 96 ])),
            alt: "",
            class: "size-16 rounded-md object-cover shrink-0" %>
    <% end %>

    <div class="flex-1 min-w-40">
      <h3 class="font-semibold text-text-heading">
        <%= link_to room_card_title(room), room_path(room),
              data: { turbo_frame: "_top" },
              class: "hover:underline focus-ring rounded" %>
      </h3>
      <span class="block text-sm text-text-muted"><%= room_card_meta(room) %></span>
    </div>

    <span class="flex items-center gap-2 shrink-0">
      <span class="text-right">
        <span class="block text-xl font-semibold text-text-heading tabular-nums leading-tight">
          <%= room.instructional_seat_count.to_i %>
        </span>
        <span class="block text-xs uppercase tracking-wide text-text-muted">
          <%= t("rooms.row.seats_label", count: room.instructional_seat_count.to_i) %>
        </span>
      </span>
      <% if room.ada_seat_count.to_i.positive? %>
        <%= ui :badge, t("rooms.row.ada", count: room.ada_seat_count), variant: :soft, tone: :success %>
      <% end %>
      <%= render "rooms/save_toggle", room: room, saved_id: saved_room_ids[room.id] %>
    </span>
  </div>

  <% chips = room_card_chips(room) %>
  <% if chips.any? %>
    <ul class="flex flex-wrap gap-1.5 pt-2">
      <% chips.first(RoomsHelper::CARD_TAG_LIMIT).each do |chip| %>
        <li><%= render "rooms/characteristic_chip", chip: chip, emphasis: true %></li>
      <% end %>
    </ul>
  <% end %>

  <% alerts = note_stats[[ room.id, true ]].to_i %>
  <% notes  = note_stats[[ room.id, false ]].to_i %>
  <% if alerts.positive? || notes.positive? %>
    <p class="flex flex-wrap items-center gap-2 pt-2 text-sm text-text-muted">
      <% if alerts.positive? %>
        <%= ui :badge, t("rooms.row.alerts", count: alerts), variant: :soft, tone: :warning %>
      <% end %>
      <% if notes.positive? %>
        <span><%= t("rooms.row.notes", count: notes) %></span>
      <% end %>
    </p>
  <% end %>

  <% remainder = chips.drop(RoomsHelper::CARD_TAG_LIMIT) %>
  <% if remainder.any? %>
    <details class="group mt-1">
      <summary class="list-none min-h-11 inline-flex items-center gap-1 cursor-pointer
                      text-sm text-text-body focus-ring rounded
                      transition-colors hover:text-interactive">
        <%= t("rooms.row.more_features", count: remainder.size) %>
        <%= icon(:chevron_down, size: :sm,
              class: "text-text-muted transition-transform group-open:rotate-180") %>
      </summary>
      <ul class="flex flex-wrap gap-1.5 pb-2 pt-2">
        <% remainder.each do |chip| %>
          <li><%= render "rooms/characteristic_chip", chip: chip %></li>
        <% end %>
      </ul>
    </details>
  <% end %>
</li>
