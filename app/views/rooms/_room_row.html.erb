<%# locals: (room:) %>
<%# MiClassrooms Phase 3 Task 5 (Brief §5.2): one result row per room. A native
    <details>/<summary> disclosure — no JS needed for keyboard operability or
    the expand/collapse semantics (Enter/Space on the focused summary toggles
    it; screen readers announce the expanded state natively). No link to
    rooms#show: that route ships in phase 4, so the row's summary IS the
    interactive surface. %>
<%# Redesign (2026-07 sprint): each result is a card in the index grid — the
    border moved from a row divider to the card itself; the <details>
    disclosure interaction is unchanged. %>
<li class="rounded-lg border border-border p-3">
  <details class="group">
    <summary class="list-none min-h-11 flex flex-wrap items-center gap-4 py-1 px-2 -mx-2
                    cursor-pointer rounded-md focus-ring">
      <% if (thumbnail = room_thumbnail_image(room)) %>
        <%= ui :image,
              src: url_for(thumbnail.image.variant(resize_to_fill: [ 96, 96 ])),
              alt: room.display_name,
              class: "size-16 rounded-md object-cover shrink-0" %>
      <% else %>
        <span class="size-16 rounded-md bg-surface-sunken flex items-center justify-center shrink-0" aria-hidden="true">
          <%= icon(:camera, size: :md, class: "text-text-muted") %>
        </span>
        <span class="sr-only"><%= t("rooms.row.no_thumbnail") %></span>
      <% end %>

      <span class="flex-1 min-w-40">
        <span class="block font-semibold text-text-heading"><%= room.display_name %></span>
        <span class="block text-sm text-text-muted">
          <%= room.building.display_name %><% if room.floor %> · <%= room.floor.label %><% end %>
        </span>
      </span>

      <span class="flex items-center gap-2 shrink-0">
        <%# Sprint card anatomy: the seat count is the card's number — split
            from its label so it reads at a glance across the grid. %>
        <span class="text-right">
          <span class="block text-xl font-semibold text-text-heading tabular-nums leading-tight">
            <%= room.instructional_seat_count.to_i %>
          </span>
          <span class="block text-xs uppercase tracking-wide text-text-muted">
            <%= t("rooms.row.seats_label", count: room.instructional_seat_count.to_i) %>
          </span>
        </span>
        <% if room.ada_seat_count.to_i.positive? %>
          <%= ui :badge, t("rooms.row.ada", count: room.ada_seat_count), variant: :soft, tone: :info %>
        <% end %>
      </span>

      <span class="flex items-center gap-1.5 shrink-0">
        <% room_characteristic_icons(room).each do |icon_key, label| %>
          <%# NON-interactive chip: HTML5 forbids focusable/interactive descendants
              of <summary> (axe-core nested-interactive), so this is a plain <span>
              — the aria-hidden icon plus a visually-hidden label give the chip an
              accessible name WITHOUT any tabindex/keydown element. The long
              description / hover tooltip lives in the glossary (Task 7) and on the
              room detail page (phase 4), not on this row chip. %>
          <span class="inline-flex items-center">
            <span class="sr-only"><%= label %></span>
            <%= icon(icon_key, size: :sm, class: "text-text-muted") %>
          </span>
        <% end %>
      </span>

      <%= icon(:chevron_down, size: :sm,
            class: "text-text-muted shrink-0 transition-transform group-open:rotate-180") %>
    </summary>

    <div class="pl-2 pb-4 pt-1 text-sm text-text-body space-y-1">
      <% if room.room_number.present? %>
        <p><span class="font-medium text-text-heading"><%= t("rooms.row.room_number") %>:</span> <%= room.room_number %></p>
      <% end %>
      <% if room.unit %>
        <p><span class="font-medium text-text-heading"><%= t("rooms.row.unit") %>:</span> <%= room.unit.display_name %></p>
      <% end %>
      <% labels = room_characteristic_labels(room) %>
      <% if labels.any? %>
        <p>
          <span class="font-medium text-text-heading"><%= t("rooms.row.characteristics_heading") %>:</span>
          <%= labels.join(", ") %>
        </p>
      <% end %>
    </div>
  </details>
</li>
