<%#
  Fork override of lsa_tdx_feedback's shared/_feedback_modal partial (Rails
  serves this app-side view in place of the gem's). Two standards gaps closed
  vs. the gem's original, both upstreamable:
    - I18n: every visible string comes from the feedback.* locale (the gem
      hardcodes English), so the brand invariant + our no-hardcoded-strings rule
      hold.
    - Dialog semantics: role="dialog" + aria-modal + aria-labelledby wire the
      overlay to assistive tech (the gem shipped a bare <div>).
  Everything the gem's JS and our AAA CSS override bind to is preserved exactly:
  element IDs (#lsa-tdx-feedback-modal/-form/-trigger/-message), the class names,
  the field `name`s (category/feedback/email/url/user_agent/additional_info), and
  the inline display:none the JS toggles to show/hide (CSP allows inline style).
  Prefill ivars are set by set_lsa_tdx_feedback_data (see the initializer).
%>
<div id="lsa-tdx-feedback-modal" class="lsa-tdx-feedback-modal" style="display: none;"
     role="dialog" aria-modal="true" aria-labelledby="lsa-tdx-feedback-title">
  <div class="lsa-tdx-feedback-modal-backdrop"></div>
  <div class="lsa-tdx-feedback-modal-content">
    <div class="lsa-tdx-feedback-modal-header">
      <h2 id="lsa-tdx-feedback-title">
        <%= "[#{@lsa_tdx_feedback_app_name}]: " if defined?(@lsa_tdx_feedback_app_name) && @lsa_tdx_feedback_app_name.present? %><%= t("feedback.new.title") %>
      </h2>
      <button type="button" class="lsa-tdx-feedback-close-btn" aria-label="<%= t("feedback.form.close") %>">&times;</button>
    </div>

    <div class="lsa-tdx-feedback-modal-body">
      <form id="lsa-tdx-feedback-form">
        <div class="lsa-tdx-feedback-form-group">
          <label for="lsa-tdx-feedback-category"><%= t("feedback.form.category_label") %></label>
          <select id="lsa-tdx-feedback-category" name="category" required>
            <option value=""><%= t("feedback.form.category_prompt") %></option>
            <option value="bug"><%= t("feedback.form.categories.bug") %></option>
            <option value="suggestion"><%= t("feedback.form.categories.suggestion") %></option>
            <option value="feature"><%= t("feedback.form.categories.feature") %></option>
            <option value="general"><%= t("feedback.form.categories.general") %></option>
            <option value="other"><%= t("feedback.form.categories.other") %></option>
          </select>
        </div>

        <div class="lsa-tdx-feedback-form-group">
          <label for="lsa-tdx-feedback-feedback">
            <%= t("feedback.form.message_label") %> <span aria-hidden="true">*</span>
          </label>
          <textarea
            id="lsa-tdx-feedback-feedback"
            name="feedback"
            required
            rows="5"
            placeholder="<%= t("feedback.form.message_placeholder") %>"
          ></textarea>
        </div>

        <div class="lsa-tdx-feedback-form-group">
          <label for="lsa-tdx-feedback-email">
            <%= t("feedback.form.email_label") %> <span aria-hidden="true">*</span>
          </label>
          <input
            type="email"
            id="lsa-tdx-feedback-email"
            name="email"
            placeholder="<%= t("feedback.form.email_placeholder") %>"
            required
            value="<%= @lsa_tdx_feedback_user_email if defined?(@lsa_tdx_feedback_user_email) && @lsa_tdx_feedback_user_email.present? %>"
          >
          <small class="lsa-tdx-feedback-help-text"><%= t("feedback.form.email_help") %></small>
        </div>

        <div class="lsa-tdx-feedback-form-group">
          <label for="lsa-tdx-feedback-additional-info"><%= t("feedback.form.additional_info_label") %></label>
          <textarea
            id="lsa-tdx-feedback-additional-info"
            name="additional_info"
            rows="3"
            placeholder="<%= t("feedback.form.additional_info_placeholder") %>"
          ></textarea>
        </div>

        <!-- Hidden fields for context -->
        <input type="hidden" name="url" value="<%= @lsa_tdx_feedback_current_url if defined?(@lsa_tdx_feedback_current_url) %>">
        <input type="hidden" name="user_agent" value="<%= @lsa_tdx_feedback_user_agent if defined?(@lsa_tdx_feedback_user_agent) %>">
      </form>
    </div>

    <div class="lsa-tdx-feedback-modal-footer">
      <button type="button" class="lsa-tdx-feedback-btn lsa-tdx-feedback-btn-secondary lsa-tdx-feedback-cancel-btn">
        <%= t("feedback.form.cancel") %>
      </button>
      <button type="submit" form="lsa-tdx-feedback-form" class="lsa-tdx-feedback-btn lsa-tdx-feedback-btn-primary lsa-tdx-feedback-submit-btn">
        <span class="lsa-tdx-feedback-btn-text"><%= t("feedback.form.submit") %></span>
        <span class="lsa-tdx-feedback-loading-spinner" style="display: none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" opacity="0.25"/>
            <path d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" fill="currentColor"/>
          </svg>
          <%= t("feedback.form.sending") %>
        </span>
      </button>
    </div>

    <!-- Success/Error Messages -->
    <div id="lsa-tdx-feedback-message" class="lsa-tdx-feedback-message" style="display: none;" role="status" aria-live="polite">
      <div class="lsa-tdx-feedback-message-content"></div>
    </div>
  </div>
</div>

<%# Feedback trigger — the gem's built-in floating button, gated on our
    FEEDBACK_FLOATING_TRIGGER config. The /contact CTA opens the modal
    regardless; this is the always-on button. %>
<% if feedback_floating_trigger? %>
  <button id="lsa-tdx-feedback-trigger" class="lsa-tdx-feedback-trigger-btn" title="<%= t("feedback.trigger.title") %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20 2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h4l4 4 4-4h4c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/>
    </svg>
    <span class="lsa-tdx-feedback-trigger-text"><%= t("feedback.trigger.label") %></span>
  </button>
<% end %>
