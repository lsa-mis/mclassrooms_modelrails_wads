<%# locals: (notable:) %>
<%# MiClassrooms Phase 4 Task 4 (Brief §5.3) / Phase 5 Task 7 (Brief §14.1,
    D15): live, interactive notes for the room detail page — the notable's
    own notes (alerts first, then plain), then (when the notable responds
    to #building — true for Room) the BUILDING's notes under an I18n
    subheading. Phase 5 upgrades phase 4's read-only version in place:
    each section gets its own `turbo_stream_from` subscription and roots
    container, so a create/update/destroy anywhere reaches every open page
    live via Note's own Broadcastable wiring (app/models/note.rb).

    Deliberately NOT implemented by rendering this partial recursively for
    the building (notable: building) — that would nest a "Notes" <h2> INSIDE
    the "Building notes" <h3>, an inverted heading order (WCAG 2.4.6/1.3.1).
    Both sections are handled inline here instead, so heading levels stay
    controlled and correct.

    Renders nothing when there are no notes anywhere AND the current actor
    can't create one — an upgrade of phase 4's "nothing at all when empty"
    rule: Phase 5 turns this into an authoring surface, so a section with
    zero notes but a create-eligible actor still renders (heading + empty
    list + create form) rather than disappearing entirely. %>
<%
  preload = [ :author, :rich_text_body ]
  own_roots = notable.notes.alerts.roots.includes(*preload).to_a +
              notable.notes.plain_notes.roots.includes(*preload).to_a
  own_can_create = policy(Note.new(notable: notable)).create?

  building = notable.respond_to?(:building) ? notable.building : nil
  building_roots = building ? (building.notes.alerts.roots.includes(*preload).to_a +
                                building.notes.plain_notes.roots.includes(*preload).to_a) : []
  building_can_create = building ? policy(Note.new(notable: building)).create? : false
%>
<% if own_roots.any? || own_can_create || building_roots.any? || building_can_create %>
  <section class="mt-8">
    <h2 class="text-lg font-semibold text-text-heading"><%= t("rooms.show.notes_heading") %></h2>

    <% if own_roots.any? || own_can_create %>
      <%= turbo_stream_from notable %>
      <ul id="<%= dom_id(notable) %>_notes" class="mt-2 space-y-3">
        <% own_roots.each do |note| %>
          <%= render "notes/note", note: note %>
        <% end %>
      </ul>

      <% if own_can_create %>
        <div id="<%= dom_id(notable, :new_note) %>" class="mt-3">
          <%= render "notes/form", notable: notable %>
        </div>
      <% end %>
    <% end %>

    <% if building_roots.any? || building_can_create %>
      <div class="mt-4">
        <h3 class="text-base font-semibold text-text-heading">
          <%= t("rooms.show.building_notes_heading") %>
        </h3>

        <%= turbo_stream_from building %>
        <ul id="<%= dom_id(building) %>_notes" class="mt-2 space-y-3">
          <% building_roots.each do |note| %>
            <%= render "notes/note", note: note %>
          <% end %>
        </ul>

        <% if building_can_create %>
          <div id="<%= dom_id(building, :new_note) %>" class="mt-3">
            <%= render "notes/form", notable: building %>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>
<% end %>
