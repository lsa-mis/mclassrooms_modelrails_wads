# Copy this file to .env and fill in the values you need for local development.
# Production secrets live in Rails credentials (bin/rails credentials:edit) or
# in .kamal/secrets — never commit real secrets to .env files.
#
# Every var here has a working default unless marked "required". The full
# reference (with the config that reads each one) lives in app/docs at /docs:
# deployment.md for tuning/hosts, presets.md for tenancy.

# === Rails ===

# Required to run the production-style image locally (e.g. docker compose
# against the prod Dockerfile). Not needed for `bin/dev`.
# RAILS_MASTER_KEY=

# Hostname used to build absolute URLs in mailer links. Defaults to
# example.com — set it on staging/prod or emailed links point nowhere.
# RAILS_HOST=app.example.com

# Log verbosity in production (default: info).
# RAILS_LOG_LEVEL=info

# === Passkeys (WebAuthn) ===

# Passkey relying-party origin override (default: derived from RAILS_HOST).
# Only set if the public origin differs from the app host. See app/docs/developer/passkeys.md.
# WEBAUTHN_ORIGIN=https://app.example.com

# Passkey relying-party ID override (default: hostname from WEBAUTHN_ORIGIN).
# Only set if you need a custom RP ID. See app/docs/developer/passkeys.md.
# WEBAUTHN_RP_ID=app.example.com

# === Okta OIDC sign-in (Phase 0 Task 6) ===
# Unlike the Google/GitHub OAuth strategies (configured via
# `bin/rails credentials:edit`), Okta is a per-deployment identity provider —
# MiClassrooms points this at the University of Michigan's Okta org — so it's
# configured via ENV instead. All three are required together; the strategy
# is skipped at boot (no Okta sign-in button, no /auth/okta route hit) when
# OKTA_ISSUER is unset, so a fork without Okta creds still boots cleanly.

# Root URL of the Okta authorization server, e.g. https://your-org.okta.com
# (no trailing slash). Also drives the RP-initiated logout redirect in
# SessionsController#destroy (`{OKTA_ISSUER}/v1/logout`).
# OKTA_ISSUER=https://your-org.okta.com

# OIDC app client id/secret from the Okta admin console.
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=

# === SSO-only posture (Phase 0 Task 7) ===
# Production sign-in offers ONLY Google + Okta: the sign-in page hides the
# email/password/magic-link form and passkey prompt, and drops the GitHub
# button (its strategy stays configured, just unreferenced). This is a
# UI-only gate — SessionsController#lookup and MagicLinkCallbacksController
# stay reachable so the seeded workspace Owner (a password-set link, not
# SSO — see db/seeds.rb) always has a working break-glass sign-in path.
# Default: true in production, false everywhere else. See
# app/lib/auth_config.rb and config/initializers/auth.rb.
# AUTH_SSO_ONLY=true

# Comma-separated email domains allowed to sign in via Google (Okta is NOT
# subject to this — org membership is Okta's own gate). Case-insensitive
# EXACT match on the domain part of the OAuth email; empty/unset disables
# the allowlist (every domain passes) — the dev-friendly default. See
# OmniauthCallbacksController#google_domain_allowed?.
ALLOWED_GOOGLE_DOMAINS=umich.edu,lsa.umich.edu

# === Non-production test login (Phase 0 Task 8) ===
# Accessibility crawlers (Siteimprove) can't complete Google/Okta SSO, so
# non-production environments can expose GET /test_login?token=... — it
# creates/signs in a fixed test user (test-login@umich.edu) and redirects to
# root. Structurally absent in production regardless of these vars: the
# route is only drawn when !Rails.env.production? AND this token is present
# (AuthConfig.test_login_enabled?, config/routes/app.rb). Leave BOTH empty in
# production-like environments — an unset TEST_LOGIN_TOKEN keeps the route
# from being drawn at all, which is the point.

# Shared secret the crawler passes as ?token=. Required for the route to be
# drawn in any non-production environment; compared with
# ActiveSupport::SecurityUtils.secure_compare. Leave unset/empty everywhere
# the backdoor isn't needed.
# TEST_LOGIN_TOKEN=

# "true" grants the test user the Admin role in its workspace membership
# instead of the default Viewer; unset (or any other value) downgrades back
# to Viewer on the next test login. See TestLoginsController#grant_test_role.
# TEST_LOGIN_ADMIN=true

# === Kamal deployment ===

# Personal access token or registry password used by `kamal deploy` to push to
# GitHub Container Registry. See config/deploy.yml:registry for the username.
# KAMAL_REGISTRY_PASSWORD=

# === Server tuning (optional — all have working defaults) ===
# See app/docs/developer/deployment.md for the Puma/Solid Queue topology these affect.

# Puma worker processes (default: 1 — correct for a single-box SQLite fork).
# WEB_CONCURRENCY=1

# Puma threads per worker; also the SQLite connection pool size (default: 5 dev / 3 prod).
# RAILS_MAX_THREADS=3

# Solid Queue worker processes (default: 1). Increase only after moving jobs
# out of Puma (SOLID_QUEUE_IN_PUMA, set in config/deploy.yml — not here).
# JOB_CONCURRENCY=1

# Local dev server port (default: 3000).
# PORT=3000

# === Signup gating ===

# Controls public signup behavior (default: invite_only).
# - "invite_only": /registrations/new is closed unless the visitor has a valid
#   invitation token in session
# - "open": anyone can sign up at /registrations/new
# SIGNUP_MODE=invite_only

# Instance ceiling on which workspace join strategies are allowed, comma-
# separated (default: invite). Valid values: invite, open_link. When open_link
# isn't permitted, the workspace setting is shown disabled. See
# app/docs/developer/presets-open-saas.md.
# SIGNUP_PERMITTED_JOIN_STRATEGIES=invite

# === Tenancy preset ===
# Pick a preset at setup time — switching later is a data migration, not a
# config flip. Full matrix in app/docs/developer/presets.md and
# app/docs/developer/presets-single-tenant.md.
#
# MiClassrooms is single-tenant (Phase 0 Task 4): everyone shares ONE
# workspace, there are no personal workspaces, and workspace creation is
# disabled. These are the real values this fork runs with — not just
# documentation placeholders — so a fresh `cp .env.example .env` reproduces
# the intended posture out of the box.

# Which workspace (if any) a new user lands in on signup.
# Valid: personal (auto-create their own) · shared (join the one shared workspace) · none (no workspace — identity-only; see app/docs/developer/presets-none.md)
WORKSPACE_ON_SIGNUP=shared

# Whether the "New workspace" UI + route are available (default: enabled).
# Valid values: enabled, disabled. Set disabled for single-tenant / solo.
TENANCY_WORKSPACE_CREATION=disabled

# === Shared-preset seeds (only when WORKSPACE_ON_SIGNUP=shared) ===
# Consumed by `bin/rails db:seed` to bootstrap the shared workspace + its
# initial Owner. See app/docs/developer/presets-single-tenant.md.

# Slug for the shared workspace — REQUIRED when WORKSPACE_ON_SIGNUP=shared.
TENANCY_SHARED_WORKSPACE_SLUG=miclassrooms

# Display name for the shared workspace (default: slug titleized).
TENANCY_SHARED_WORKSPACE_NAME=MiClassrooms

# Fork deviation (MiClassrooms Task 4): role slug (owner, admin, member, or
# viewer — see Role::SYSTEM_DEFAULTS) a new user is granted when self-joining
# the shared workspace (User#join_shared_workspace). The template hardcodes
# "member"; this knob (config.x.tenancy.shared_join_role,
# TenancyConfig.shared_join_role) lets a fork override it. MiClassrooms uses
# "viewer" (empty-permissions, read-only tier) — every authenticated U-M user
# lands read-only until an admin promotes them. Defaults to "member" when unset.
TENANCY_SHARED_JOIN_ROLE=viewer

# Initial Owner account the seed creates and mails a password-set link to.
TENANCY_OWNER_EMAIL=owner@miclassrooms.example
# TENANCY_OWNER_FIRST_NAME=Workspace
# TENANCY_OWNER_LAST_NAME=Owner

# Host used in the seed's logged workspace URL and in the
# `tenancy:owner_setup_link` sign-in link (default: localhost — set on prod).
# APP_HOST=app.example.com

# === U-M Facilities gateway sync (Phase 2 ingestion) ===
# Required for UmApi::TokenCache / UmApi::Client (app/lib/um_api/) — the
# sync services pull building/classroom/department data from the University
# of Michigan's API gateway on a client-credentials OAuth2 grant, one scope
# per data domain. No defaults: every var below is read via ENV.fetch with
# no fallback, so a checkout without these set fails loudly the first time a
# sync job runs rather than silently hitting a placeholder host. Specs never
# read these — spec/support/um_api_stubs.rb stubs the gateway via WebMock.

# OAuth2 client-credentials token endpoint. Ask the U-M API gateway team for
# the production URL; there is no working default.
# UM_API_TOKEN_URL=https://gw.api.it.umich.edu/um/oauth2/token

# Client id/secret issued by the U-M API gateway for this application.
# UM_API_CLIENT_ID=
# UM_API_CLIENT_SECRET=

# Base URL for the U-M Facilities gateway itself (UmApi::Client prepends
# this to every endpoint path — e.g. "/bf/Buildings/v2/Campuses").
# UM_API_BASE_URL=https://gw.api.it.umich.edu/um

# Dry-run guard for the nightly pipeline (Sync::RunPipeline.call's default —
# app/lib/sync/run_pipeline.rb, run nightly by SyncNightlyJob). Any
# non-empty value (e.g. "true") makes every phase's `guarded_write` skip its
# actual deactivation/deletion/clear while still reporting accurate "would
# have" counters on the SyncRun/SyncPhase rows — nothing destructive runs.
# Unset (the default) means live writes.
# API_UPDATE_DELETE_DRY_RUN=true

# Optional Geocoder lookup override for GeocodeBuildingJob (app/jobs/
# geocode_building_job.rb). Unset uses the geocoder gem's default lookup
# (:nominatim); set to any other supported Geocoder::Lookup key (e.g.
# "google", "here") to switch providers without a code change.
# GEOCODER_LOOKUP=nominatim
