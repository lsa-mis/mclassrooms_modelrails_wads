<%# Autoplaying carousel (3s) with a WCAG 2.2.2 pause/play toggle. %>
<%# Local SVG placeholder images — no network dependency. %>
<div data-test="carousel" class="max-w-md">
  <%= render(UI::CarouselComponent.new(label: "Auto gallery", autoplay: 3000)) do |c| %>
    <% c.with_slide { tag.img(src: PreviewSupport.placeholder_image_uri(800, 400, "Auto one"), alt: "Auto one", width: 800, height: 400, class: "w-full") } %>
    <% c.with_slide { tag.img(src: PreviewSupport.placeholder_image_uri(800, 400, "Auto two"), alt: "Auto two", width: 800, height: 400, class: "w-full") } %>
  <% end %>
</div>
