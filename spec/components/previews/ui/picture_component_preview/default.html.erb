<div id="pic-scope" class="max-w-md">
  <%# Art direction: a wide landscape crop on large screens, a square crop on small. %>
  <%# Local SVG placeholder images — no network dependency. %>
  <%= ui :picture,
        src: PreviewSupport.placeholder_image_uri(800, 450),
        alt: "A river winding through a forested canyon",
        width: 800,
        height: 450,
        class: "rounded-lg" do |p| %>
    <% p.with_source(srcset: PreviewSupport.placeholder_image_uri(800, 450), media: "(min-width: 640px)") %>
    <% p.with_source(srcset: PreviewSupport.placeholder_image_uri(400, 400), media: "(max-width: 639px)") %>
  <% end %>
</div>
