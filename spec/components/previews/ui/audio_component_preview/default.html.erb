<%# Local data-URI source with preload="none" — no network dependency. %>
<%# The 0b spec asserts the <audio> markup + axe, never media loading. %>
<div data-test="audio">
  <%= render(UI::AudioComponent.new(preload: :none)) do |a| %>
    <% a.with_source(src: "data:audio/mpeg,", type: "audio/mpeg") %>
  <% end %>
</div>
