<%# Local SVG placeholder images — no network dependency. %>
<%# The 0b spec asserts markup + lightbox behavior, never image loading. %>
<div data-test="gallery">
  <%= render(UI::GalleryComponent.new(cols: 3)) do |g| %>
    <% g.with_image(src: PreviewSupport.placeholder_image_uri(600, 600, "Forest canopy"), alt: "Forest canopy") %>
    <% g.with_image(src: PreviewSupport.placeholder_image_uri(600, 600, "City street"), alt: "City street", caption: "Downtown") %>
    <% g.with_image(src: PreviewSupport.placeholder_image_uri(600, 600, "Mountain lake"), alt: "Mountain lake") %>
  <% end %>
</div>
