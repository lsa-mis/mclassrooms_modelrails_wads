<%# Local SVG poster + local data-URI sources with preload="none" — no network dependency. %>
<%# The 0b spec asserts <video> markup + axe (never media loading). %>
<div data-test="video" class="max-w-md">
  <%= render(UI::VideoComponent.new(poster: PreviewSupport.placeholder_image_uri(640, 360, "Video poster"), preload: :none)) do |v| %>
    <% v.with_source(src: "data:video/mp4,", type: "video/mp4") %>
    <% v.with_source(src: "data:video/webm,", type: "video/webm") %>
  <% end %>
</div>
